    include->web_core.flow

    GameEngine[GameEngine.ts{}]
    
    @@main.code
        const web = new WebServer();
        
        web.get("/", (req: any, res: any) => {
            res.sendFile(path.join(process.cwd(), "index.html"));
        });

        web.start();
    @main.end

    web->index.html.code
    <!DOCTYPE html>
    <html>
    <head>
        <title>SoT - Space Invaders</title>
        <style>
            body { margin: 0; background: #000; overflow: hidden; color: #0f0; font-family: 'Courier New', monospace; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; }
            canvas { border: 2px solid #0f0; background: #000; image-rendering: pixelated; }
            #ui { margin-top: 10px; font-size: 20px; }
        </style>
    </head>
    <body>
        <div id="ui">SCORE: <span id="score">0</span></div>
        <canvas id="game" width="600" height="600"></canvas>
        <div style="margin-top: 10px;">A/D to Move | SPACE to Shoot</div>

        <script>
            const canvas = document.getElementById('game');
            const ctx = canvas.getContext('2d');
            const scoreEl = document.getElementById('score');

            let score = 0;
            let gameOver = false;

            const ship = { x: 280, y: 550, w: 40, h: 20, speed: 5 };
            const bullets = [];
            const invaders = [];
            const invaderBullets = [];

            // Initialize Invaders
            for (let r = 0; r < 4; r++) {
                for (let c = 0; c < 10; c++) {
                    invaders.push({ x: 50 + c * 50, y: 50 + r * 40, w: 30, h: 20, alive: true });
                }
            }

            let moveRight = true;
            let keys = {};

            window.addEventListener('keydown', e => keys[e.code] = true);
            window.addEventListener('keyup', e => keys[e.code] = false);

            function update() {
                if (gameOver) return;

                // Move Ship
                if (keys['KeyA'] && ship.x > 0) ship.x -= ship.speed;
                if (keys['KeyD'] && ship.x < canvas.width - ship.w) ship.x += ship.speed;
                if (keys['Space']) {
                    if (bullets.length < 3) {
                        bullets.push({ x: ship.x + ship.w / 2 - 2, y: ship.y, w: 4, h: 10 });
                        keys['Space'] = false; // Prevent rapid fire
                    }
                }

                // Update Bullets
                bullets.forEach((b, i) => {
                    b.y -= 7;
                    if (b.y < 0) bullets.splice(i, 1);
                });

                // Move Invaders
                let edge = false;
                invaders.forEach(inv => {
                    if (!inv.alive) return;
                    inv.x += moveRight ? 1 : -1;
                    if (inv.x > canvas.width - inv.w || inv.x < 0) edge = true;
                });

                if (edge) {
                    moveRight = !moveRight;
                    invaders.forEach(inv => inv.y += 10);
                }

                // Collision Detection
                bullets.forEach((b, bi) => {
                    invaders.forEach(inv => {
                        if (inv.alive && b.x < inv.x + inv.w && b.x + b.w > inv.x && b.y < inv.y + inv.h && b.y + b.h > inv.y) {
                            inv.alive = false;
                            bullets.splice(bi, 1);
                            score += 10;
                            scoreEl.innerText = score;
                        }
                    });
                });

                if (invaders.every(inv => !inv.alive)) {
                    ctx.fillStyle = "#0f0";
                    ctx.font = "40px Courier New";
                    ctx.fillText("VICTORY!", 200, 300);
                    gameOver = true;
                }
            }

            function draw() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                // Draw Ship
                ctx.fillStyle = '#0f0';
                ctx.fillRect(ship.x, ship.y, ship.w, ship.h);

                // Draw Bullets
                ctx.fillStyle = '#fff';
                bullets.forEach(b => ctx.fillRect(b.x, b.y, b.w, b.h));

                // Draw Invaders
                ctx.fillStyle = '#f00';
                invaders.forEach(inv => {
                    if (inv.alive) ctx.fillRect(inv.x, inv.y, inv.w, inv.h);
                });

                if (gameOver) return;
                requestAnimationFrame(() => {
                    update();
                    draw();
                });
            }

            draw();
        </script>
    </body>
    </html>
    web->index.html.end
