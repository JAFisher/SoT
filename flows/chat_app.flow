graph TD
    include->web_core.flow
    include->chat_engine.flow

    @@main.code
        const web = new WebServer();
        const chat = new ChatManager();

        chat.attach(web.server);

        web.get("/", (req: any, res: any) => {
            res.sendFile(path.join(process.cwd(), "index.html"));
        });

        web.start();
    @main.end

    web->index.html.code
    <!DOCTYPE html>
    <html>
    <head>
        <title>SoT Chat Room</title>
        <style>
            body { font-family: 'Inter', sans-serif; background: #0f172a; color: white; display: flex; flex-direction: column; height: 100vh; margin: 0; }
            #messages { flex: 1; overflow-y: auto; padding: 20px; list-style: none; }
            #messages li { margin-bottom: 10px; padding: 10px; background: #1e293b; border-radius: 8px; border-left: 4px solid #38bdf8; }
            #messages li b { color: #38bdf8; margin-right: 10px; }
            #form { display: flex; padding: 20px; background: #1e293b; gap: 10px; }
            input { flex: 1; padding: 12px; border-radius: 6px; border: 1px solid #334155; background: #0f172a; color: white; outline: none; }
            button { padding: 12px 24px; background: #38bdf8; color: #0f172a; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; transition: 0.2s; }
            button:hover { background: #7dd3fc; }
            #login { position: fixed; inset: 0; background: #0f172a; display: flex; align-items: center; justify-content: center; z-index: 10; }
            .login-box { background: #1e293b; padding: 40px; border-radius: 12px; text-align: center; border: 1px solid #334155; }
        </style>
    </head>
    <body>
        <div id="login">
            <div class="login-box">
                <h2>Join Chat Room</h2>
                <input type="text" id="username" placeholder="Enter your username...">
                <button onclick="join()">Join</button>
            </div>
        </div>

        <ul id="messages"></ul>
        <div id="form">
            <input type="text" id="input" placeholder="Type a message...">
            <button onclick="send()">Send</button>
        </div>

        <script src="/socket.io/socket.io.js"></script>
        <script>
            const socket = io();
            const messages = document.getElementById('messages');
            const input = document.getElementById('input');
            const login = document.getElementById('login');
            const userIn = document.getElementById('username');

            function join() {
                const name = userIn.value.trim();
                if (name) {
                    socket.emit('join', name);
                    login.style.display = 'none';
                }
            }

            function send() {
                const text = input.value.trim();
                if (text) {
                    socket.emit('chatMessage', text);
                    input.value = '';
                }
            }

            socket.on('message', (msg) => {
                const item = document.createElement('li');
                item.innerHTML = `<b>${msg.user}</b> ${msg.text}`;
                messages.appendChild(item);
                messages.scrollTop = messages.scrollHeight;
            });

            input.addEventListener('keypress', (e) => { if (e.key === 'Enter') send(); });
            userIn.addEventListener('keypress', (e) => { if (e.key === 'Enter') join(); });
        </script>
    </body>
    </html>
    web->index.html.end
