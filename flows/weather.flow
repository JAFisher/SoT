graph TD
  %% ---- External Library ----
  extern->axios from 'axios'

  %% ---- Weather Service ----
  WeatherService[WeatherService.ts{apiKey: string, history: WeatherUpdate[]}]
  
  type->WeatherUpdate{temp: number, condition: string, timestamp: number}

  %% ---- Async Method Logic ----
  @async @WeatherService.getWeather{city: string}: Promise<WeatherUpdate>
  @@WeatherService.getWeather.code
    console.log("[Weather] Fetching data for " + city + "...");
    // Simulating an API call with a promise
    return new Promise((resolve) => {
      setTimeout(() => {
        const update = { temp: Math.floor(Math.random() * 35), condition: 'Sunny', timestamp: Date.now() };
        this.history.push(update);
        resolve(update);
      }, 1000);
    });
  @@WeatherService.getWeather.end

  %% ---- Main Execution ----
  @@main.code
  async function testAsyncFlow() {
    console.log("=== Async Weather Service Demo ===");
    const ws = new WeatherService("secret-api-99");
    ws.history = [];

    const data = await ws.getWeather("New York");
    console.log("Weather received: " + data.temp + "°C and " + data.condition);
    console.log("History log length: " + ws.history.length);
  }
  testAsyncFlow();
  @@main.end
