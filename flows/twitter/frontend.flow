include->authfe.flow
include->feeds.flow
include->messages.flow

cliscripts->start node -e "require('fs').copyFileSync('compiled.js', 'public/compiled.js')" && npx -y http-server public -p 3000

TwitterApp[TwitterApp.ts{auth: any, feed: any, messaging: any, initialized: boolean}]
TwitterApp --> AuthFE
TwitterApp --> Feed
TwitterApp --> Messaging

@TwitterApp.constructor{}
@@TwitterApp.constructor.code
  this.auth = new AuthFE();
  this.feed = new Feed();
  this.messaging = new Messaging();
  this.initialized = false;
  this.renderCount = 0;
@@TwitterApp.constructor.end

@async @TwitterApp.init{}: void
@@TwitterApp.init.code
  if (this.initialized) return;
  this.initialized = true;

  // Create toast container
  if (!document.getElementById('toast-container')) {
    const container = document.createElement('div');
    container.id = 'toast-container';
    document.body.appendChild(container);
  }
@@TwitterApp.init.end

@async @TwitterApp.renderTimeline{containerId: string}: void
@@TwitterApp.renderTimeline.code
  const container = document.getElementById(containerId);
  if (!container) return;
  
  const tweets = await this.feed.getTimeline();
  let html = '<h3 class="timeline-header">Timeline</h3>';
  tweets.forEach(t => {
    html += this.renderSingleTweet(t);
  });
  container.innerHTML = html;
@@TwitterApp.renderTimeline.end

@TwitterApp.renderSingleTweet{t: any}: string
@@TwitterApp.renderSingleTweet.code
  const instanceId = ++this.renderCount;
  const name = t.authorName || t.authorUsername;
  const isRetweet = !!t.retweetedId;
  const retweetTag = isRetweet ? "<span class=\"retweet-tag\">🔄 Retweeted from @" + t.retweetedAuthor + "</span>" : "";
  
  const currentUser = this.auth.getCurrentUser();
  const canRetweet = currentUser && currentUser.username !== t.authorUsername;
  const retweetBtn = canRetweet ? 
    "<button class=\"tweet-btn retweet-btn\" id=\"retweet-btn-instance-" + instanceId + "\" onclick=\"window.app.retweet('" + t.id + "', " + instanceId + ")\">🔄 " + (t.retweetCount || 0) + "</button>" : "";

  return "<div class=\"tweet\" id=\"tweet-instance-" + instanceId + "\">" +
      "<div class=\"tweet-header\">" +
        "<span class=\"tweet-name\">" + name + "</span>" +
        "<span class=\"tweet-username\">@" + t.authorUsername + "</span>" +
        retweetTag +
      "</div>" +
      "<div class=\"tweet-content\">" + t.content + "</div>" +
      "<div class=\"tweet-footer\">" +
        "<button class=\"tweet-btn reply-btn\" onclick=\"window.app.startReply('" + t.id + "', '" + t.authorUsername + "', " + instanceId + ")\">💬 " + (t.repliesCount || 0) + "</button>" +
        retweetBtn +
        "<button class=\"tweet-btn like-btn\" id=\"like-btn-instance-" + instanceId + "\" onclick=\"window.app.like('" + t.id + "', " + instanceId + ")\">❤️ " + (t.likedCount || 0) + "</button>" +
        "<button class=\"tweet-btn view-replies-btn\" onclick=\"window.app.toggleReplies('" + t.id + "', " + instanceId + ")\">View Replies</button>" +
      "</div>" +
      "<div id=\"replies-instance-" + instanceId + "\" class=\"replies-container\" style=\"display: none;\"></div>" +
    "</div>";
@@TwitterApp.renderSingleTweet.end

@TwitterApp.renderSingleReply{r: any}: string
@@TwitterApp.renderSingleReply.code
  const rInstanceId = ++this.renderCount;
  const currentUser = this.auth.getCurrentUser();
  const canRetweet = currentUser && currentUser.username !== r.sender_username;
  const retweetBtn = canRetweet ? 
    "<button class=\"tweet-btn retweet-btn btn-compact\" onclick=\"window.app.retweet('" + r.id + "', " + rInstanceId + ")\">🔄 " + (r.retweetCount || 0) + "</button>" : "";

  return "<div class=\"reply\" id=\"tweet-instance-" + rInstanceId + "\">" +
    "<div class=\"reply-header\">@" + r.sender_username + "</div>" +
    "<div class=\"reply-content\">" + r.content + "</div>" +
    "<div class=\"reply-footer\">" +
      "<button class=\"tweet-btn reply-btn btn-compact\" onclick=\"window.app.startReply('" + r.id + "', '" + r.sender_username + "', " + rInstanceId + ")\">💬 " + (r.repliesCount || 0) + "</button>" +
      retweetBtn +
      "<button class=\"tweet-btn like-btn btn-compact\" id=\"like-btn-instance-" + rInstanceId + "\" onclick=\"window.app.like('" + r.id + "', " + rInstanceId + ")\">❤️ " + (r.likedCount || 0) + "</button>" +
      "<button class=\"tweet-btn view-replies-btn btn-compact\" onclick=\"window.app.toggleReplies('" + r.id + "', " + rInstanceId + ")\">View Replies</button>" +
    "</div>" +
    "<div id=\"replies-instance-" + rInstanceId + "\" class=\"replies-container\" style=\"display: none;\"></div>" +
  "</div>";
@@TwitterApp.renderSingleReply.end

@async @TwitterApp.toggleReplies{tweetId: string, instanceId: number}: void
@@TwitterApp.toggleReplies.code
  const container = document.getElementById("replies-instance-" + instanceId);
  if (!container) return;
  
  if (container.style.display === 'block') {
    container.style.display = 'none';
    return;
  }
  
  const replies = await this.feed.getReplies(tweetId);

  if (replies.length === 0) {
    container.innerHTML = '<div style="padding: 10px; color: #888;">No replies yet</div>';
  } else {
    container.innerHTML = replies.map(r => this.renderSingleReply(r)).join('');
  }
  container.style.display = 'block';
@@TwitterApp.toggleReplies.end

@async @TwitterApp.postNewTweet{authorUsername: string, content: string, repliedToId: string, retweetedId: string}: any
@@TwitterApp.postNewTweet.code
  return await this.feed.postTweet(authorUsername, content, repliedToId, retweetedId);
@@TwitterApp.postNewTweet.end

@TwitterApp.startReply{tweetId: string, author: string, instanceId: number}: void
@@TwitterApp.startReply.code
  const container = document.getElementById("replies-instance-" + instanceId);
  if (!container) return;
  
  if (container.style.display === 'none') {
    container.style.display = 'block';
  }
  
  const inputId = "reply-input-instance-" + instanceId;
  if (!document.getElementById(inputId)) {
    const inputDiv = document.createElement('div');
    inputDiv.id = inputId;
    inputDiv.className = "inline-reply-div";
    inputDiv.innerHTML = 
      "<textarea id=\"input-instance-" + instanceId + "\" class=\"inline-reply-textarea\" placeholder=\"Replying to @" + author + "...\"></textarea>" +
      "<div class=\"inline-reply-actions\">" +
        "<button class=\"btn btn-primary\" onclick=\"window.app.postInlineReply('" + tweetId + "', " + instanceId + ", '" + author + "')\">Reply</button>" +
      "</div>";
    container.prepend(inputDiv);
    document.getElementById("input-instance-" + instanceId).focus();
  } else {
    document.getElementById("input-instance-" + instanceId).focus();
  }
@@TwitterApp.startReply.end

@async @TwitterApp.postInlineReply{parentTweetId: string, instanceId: number, parentAuthor: string}: void
@@TwitterApp.postInlineReply.code
  const textarea = document.getElementById("input-instance-" + instanceId);
  const content = textarea.value;
  if (!content) return;
  
  const author = this.auth.currentUser.username;
  const res = await this.feed.postTweet(author, content, parentTweetId, '');
  
  const inputDiv = document.getElementById("reply-input-instance-" + instanceId);
  if (inputDiv) inputDiv.remove();
  
  const container = document.getElementById("replies-instance-" + instanceId);
  const newReplyHtml = this.renderSingleReply({
    id: res.id,
    sender_username: author,
    content: content,
    repliesCount: 0,
    retweetCount: 0,
    likedCount: 0
  });
  
  if (container.innerHTML.includes('No replies yet')) {
    container.innerHTML = '';
  }
  container.innerHTML = newReplyHtml + container.innerHTML;
  
  const replyBtn = document.querySelector("#tweet-instance-" + instanceId + " .reply-btn");
  if (replyBtn) {
    const current = parseInt(replyBtn.innerText.replace('💬 ', '')) || 0;
    replyBtn.innerText = "💬 " + (current + 1);
  }
@@TwitterApp.postInlineReply.end

@async @TwitterApp.like{tweetId: string, instanceId: number}: void
@@TwitterApp.like.code
  const res = await this.feed.likeMessage(tweetId);
  const btn = document.querySelector("#tweet-instance-" + instanceId + " .like-btn");
  if (btn) {
    const current = parseInt(btn.innerText.replace('❤️ ', '')) || 0;
    btn.innerText = "❤️ " + (current + 1);
  }
@@TwitterApp.like.end

@async @TwitterApp.retweet{tweetId: string, instanceId: number}: void
@@TwitterApp.retweet.code
  try {
    const result = await this.feed.retweetMessage(tweetId);
    
    if (!result.ok) {
      if (result.status === 409) {
        this.showToast("You've already retweeted this", "error");
      } else {
        this.showToast(result.data.error || "Failed to retweet", "error");
      }
      return;
    }

    const retweet = result.data;
    
    // Prepend to timeline
    const container = document.getElementById("timeline");
    if (container && retweet) {
      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = this.renderSingleTweet(retweet);
      if (tempDiv.firstElementChild) {
        container.prepend(tempDiv.firstElementChild);
        this.showToast("Retweeted successfully!", "success");
      }
    }

    // Update original button count
    const btnId = "retweet-btn-instance-" + instanceId;
    const btn = document.getElementById(btnId);
    if (btn) {
      const current = parseInt(btn.innerText.replace('🔄 ', '')) || 0;
      btn.innerText = "🔄 " + (current + 1);
    }
  } catch (e) {
    this.showToast("Connection error", "error");
  }
@@TwitterApp.retweet.end

@TwitterApp.showToast{message: string, type: string}: void
@@TwitterApp.showToast.code
  const container = document.getElementById('toast-container');
  if (!container) return;

  const toast = document.createElement('div');
  toast.className = "toast " + type;
  toast.innerText = message;
  container.appendChild(toast);

  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translate(-50%, 20px)';
    setTimeout(() => toast.remove(), 300);
  }, 3000);
@@TwitterApp.showToast.end

Rollup->{AuthFE.ts, Feed.ts, Messaging.ts, TwitterApp.ts}
