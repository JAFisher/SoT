include->authfe.flow
include->feeds.flow
include->messages.flow

cliscripts->start node -e "require('fs').copyFileSync('compiled.js', 'public/compiled.js')" && npx -y http-server public -p 3000

TwitterApp[TwitterApp.ts{auth: any, feed: any, messaging: any, initialized: boolean}]
TwitterApp --> AuthFE
TwitterApp --> Feed
TwitterApp --> Messaging

@TwitterApp.constructor{}
@@TwitterApp.constructor.code
  this.auth = new AuthFE();
  this.feed = new Feed();
  this.messaging = new Messaging();
  this.initialized = false;
@@TwitterApp.constructor.end

@async @TwitterApp.init{}: void
@@TwitterApp.init.code
  if (this.initialized) return;
  this.initialized = true;
@@TwitterApp.init.end

@async @TwitterApp.renderTimeline{containerId: string}: void
@@TwitterApp.renderTimeline.code
  const container = document.getElementById(containerId);
  if (!container) return;
  
  const tweets = await this.feed.getTimeline();
  let html = '<h3 class="timeline-header">Timeline</h3>';
  for (const t of tweets) {
    const name = t.authorUsername;
    const isRetweet = !!t.retweetedId;
    const retweetTag = isRetweet ? "<span class=\"retweet-tag\">Retweeted from @" + t.retweetedAuthor + "</span>" : "";
    html += 
      "<div class=\"tweet\" id=\"tweet-" + t.id + "\">" +
        "<div class=\"tweet-header\">" +
          "<span class=\"tweet-name\">" + name + "</span>" +
          "<span class=\"tweet-username\">@" + t.authorUsername + "</span>" +
          retweetTag +
        "</div>" +
        "<div class=\"tweet-content\">" + t.content + "</div>" +
        "<div class=\"tweet-footer\">" +
          "<button class=\"tweet-btn reply-btn\" onclick=\"window.app.startReply('" + t.id + "', '" + t.authorUsername + "')\">рЯТђ " + (t.repliesCount || 0) + "</button>" +
          "<button class=\"tweet-btn retweet-btn\" onclick=\"window.app.retweet('" + t.id + "')\">рЯФД " + (t.retweetCount || 0) + "</button>" +
          "<button class=\"tweet-btn like-btn\" onclick=\"window.app.like('" + t.id + "')\">вЭ§пЄП " + (t.likedCount || 0) + "</button>" +
          "<button class=\"tweet-btn view-replies-btn\" onclick=\"window.app.toggleReplies('" + t.id + "')\">View Replies</button>" +
        "</div>" +
        "<div id=\"replies-" + t.id + "\" class=\"replies-container\" style=\"display: none; margin-left: 20px; border-left: 2px solid #ccc; padding-left: 10px;\"></div>" +
      "</div>";
  }
  container.innerHTML = html;
@@TwitterApp.renderTimeline.end

@async @TwitterApp.toggleReplies{tweetId: string, parentTweetId?: string}: void
@@TwitterApp.toggleReplies.code

console.log("replies-"+ tweetId + (parentTweetId ? "-" + parentTweetId : ""));
  const container = document.getElementById("replies-"+ tweetId + (parentTweetId ? "-" + parentTweetId : ""));
  if (!container) return;
  
  if (container.style.display === 'block') {
    container.style.display = 'none';
    return;
  }
  
  const replies = await this.feed.getReplies(tweetId);

  if (replies.length === 0) {
    container.innerHTML = '<div style="padding: 10px; color: #888;">No replies yet</div>';
  } else {
    container.innerHTML = replies.map(r => 
      "<div class=\"reply\" id=\"replies-" + tweetId + "-" + r.id + "\" style=\"margin-bottom: 10px; border-bottom: 1px solid #eee; padding-bottom: 5px;\">" +
        "<div class=\"reply-header\" style=\"font-weight: bold; font-size: 13px;\">@" + r.sender_username + "</div>" +
        "<div class=\"reply-content\" style=\"font-size: 14px;\">" + r.content + "</div>" +
        "<div class=\"reply-footer\" style=\"margin-top: 5px;\">" +
          "<button class=\"tweet-btn reply-btn\" style=\"font-size: 12px; padding: 2px 5px;\" onclick=\"window.app.startReply('" + r.id + "', '" + r.sender_username + "')\">рЯТђ " + (r.repliesCount || 0) + "</button>" +
          "<button class=\"tweet-btn retweet-btn\" style=\"font-size: 12px; padding: 2px 5px;\" onclick=\"window.app.retweet('" + r.id + "')\">рЯФД " + (r.retweetCount || 0) + "</button>" +
          "<button class=\"tweet-btn like-btn\" style=\"font-size: 12px; padding: 2px 5px;\" onclick=\"window.app.like('" + r.id + "')\">вЭ§пЄП " + (r.likedCount || 0) + "</button>" +
          "<button class=\"tweet-btn view-replies-btn\" style=\"font-size: 12px; padding: 2px 5px;\" onclick=\"window.app.toggleReplies('" + tweetId + "', '" + r.id + "')\">View Replies</button>" +
        "</div>" +
        "<div id=\"replies-" + tweetId + "-" + r.id + "\" class=\"replies-container\" style=\"display: none; margin-left: 20px; border-left: 2px solid #ccc; padding-left: 10px;\"></div>" +
      "</div>"
    ).join('');
  }
  container.style.display = 'block';
@@TwitterApp.toggleReplies.end

@async @TwitterApp.postNewTweet{authorUsername: string, content: string, repliedToId: string, retweetedId: string}: any
@@TwitterApp.postNewTweet.code
  return await this.feed.postTweet(authorUsername, content, repliedToId, retweetedId);
@@TwitterApp.postNewTweet.end

@TwitterApp.startReply{tweetId: string, author: string}: void
@@TwitterApp.startReply.code
  const container = document.getElementById("replies-" + author + "-" + tweetId);
  if (!container) return;
  
  if (container.style.display === 'none') {
    container.style.display = 'block';
  }
  
  const inputId = "reply-input-div-" + tweetId;
  if (!document.getElementById(inputId)) {
    const inputDiv = document.createElement('div');
    inputDiv.id = inputId;
    inputDiv.className = "inline-reply-div";
    inputDiv.style.padding = "10px";
    inputDiv.style.borderBottom = "1px solid #ddd";
    inputDiv.innerHTML = 
      "<textarea id=\"input-" + tweetId + "\" style=\"width: 100%; height: 50px; margin-bottom: 5px;\" placeholder=\"Replying to @" + author + "...\"></textarea>" +
      "<div style=\"display: flex; justify-content: flex-end;\">" +
        "<button class=\"tweet-btn\" onclick=\"window.app.postInlineReply('" + tweetId + "', '" + author + "')\">Reply</button>" +
      "</div>";
    container.prepend(inputDiv);
    document.getElementById("input-" + tweetId).focus();
  } else {
    document.getElementById("input-" + tweetId).focus();
  }
@@TwitterApp.startReply.end

@async @TwitterApp.postInlineReply{parentTweetId: string, parentAuthor: string}: void
@@TwitterApp.postInlineReply.code
  const textarea = document.getElementById("input-" + parentTweetId);
  const content = textarea.value;
  if (!content) return;
  
  const author = this.auth.currentUser.username;
  const res = await this.feed.postTweet(author, content, parentTweetId, '');
  
  const inputDiv = document.getElementById("reply-input-div-" + parentTweetId);
  if (inputDiv) inputDiv.remove();
  
  const container = document.getElementById("replies-" + parentAuthor + "-" + parentTweetId);
  const newReplyHtml = 
    "<div class=\"reply\" id=\"tweet-" + res.id + "\" style=\"margin-bottom: 10px; border-bottom: 1px solid #eee; padding-bottom: 5px;\">" +
      "<div class=\"reply-header\" style=\"font-weight: bold; font-size: 13px;\">@" + author + "</div>" +
      "<div class=\"reply-content\" style=\"font-size: 14px;\">" + content + "</div>" +
      "<div class=\"reply-footer\" style=\"margin-top: 5px;\">" +
        "<button class=\"tweet-btn reply-btn\" style=\"font-size: 12px; padding: 2px 5px;\" onclick=\"window.app.startReply('" + res.id + "', '" + author + "')\">рЯТђ 0</button>" +
        "<button class=\"tweet-btn retweet-btn\" style=\"font-size: 12px; padding: 2px 5px;\" onclick=\"window.app.retweet('" + res.id + "')\">рЯФД 0</button>" +
        "<button class=\"tweet-btn like-btn\" style=\"font-size: 12px; padding: 2px 5px;\" onclick=\"window.app.like('" + res.id + "')\">вЭ§пЄП 0</button>" +
        "<button class=\"tweet-btn view-replies-btn\" style=\"font-size: 12px; padding: 2px 5px;\" onclick=\"window.app.toggleReplies('" + res.id + "', '" + parentTweetId + "')\">View Replies</button>" +
      "</div>" +
      "<div id=\"replies-" + author + "-" + res.id + "\" class=\"replies-container\" style=\"display: none; margin-left: 20px; border-left: 2px solid #ccc; padding-left: 10px;\"></div>" +
    "</div>";
  
  if (container.innerHTML.includes('No replies yet')) {
    container.innerHTML = '';
  }
  container.innerHTML = newReplyHtml + container.innerHTML;
  
  const replyBtn = document.querySelector("#tweet-" + parentTweetId + " .reply-btn");
  if (replyBtn) {
    const current = parseInt(replyBtn.innerText.replace('рЯТђ ', '')) || 0;
    replyBtn.innerText = "рЯТђ " + (current + 1);
  }
@@TwitterApp.postInlineReply.end

@async @TwitterApp.like{tweetId: string}: void
@@TwitterApp.like.code
  await this.feed.likeMessage(tweetId);
  const btn = document.querySelector("#tweet-" + tweetId + " .like-btn");
  if (btn) {
    const current = parseInt(btn.innerText.replace('вЭ§пЄП ', '')) || 0;
    btn.innerText = "вЭ§пЄП " + (current + 1);
  }
@@TwitterApp.like.end

@async @TwitterApp.retweet{tweetId: string}: void
@@TwitterApp.retweet.code
  await this.feed.retweetMessage(tweetId);
  const btn = document.querySelector("#tweet-" + tweetId + " .retweet-btn");
  if (btn) {
    const current = parseInt(btn.innerText.replace('рЯФД ', '')) || 0;
    btn.innerText = "рЯФД " + (current + 1);
  }
@@TwitterApp.retweet.end

Rollup->{AuthFE.ts, Feed.ts, Messaging.ts, TwitterApp.ts}
