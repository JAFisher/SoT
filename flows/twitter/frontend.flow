include->authfe.flow
include->feeds.flow
include->messages.flow
include->admin.flow

cliscripts->start node -e "require('fs').copyFileSync('compiled.js', 'public/compiled.js')" && npx -y http-server public -p 3000

TwitterApp[TwitterApp.ts{auth: any, feed: any, messaging: any, initialized: boolean, followedUsers: Set<string>, currentSocialUser: string, currentSocialType: string}]
TwitterApp --> AuthFE
TwitterApp --> Feed
TwitterApp --> Messaging
TwitterApp --> AdminPage

@TwitterApp.constructor{}
@@TwitterApp.constructor.code
  this.auth = new AuthFE();
  this.feed = new Feed();
  this.messaging = new Messaging();
  this.adminPage = new AdminPage();
  this.initialized = false;
  this.renderCount = 0;
  this.tweetsOffset = 0;
  this.profileTweetsOffset = 0;
  this.notificationsOffset = 0;
  this.tweetsLimit = 25;
  this.followedUsers = new Set();
  this.currentSocialUser = "";
  this.currentSocialType = "";
  this.searchOffset = 0;
  this.currentSearchQuery = "";
@@TwitterApp.constructor.end

@async @TwitterApp.init{}: void
@@TwitterApp.init.code
  if (this.initialized) return;
  this.initialized = true;

  // Create toast container
  if (!document.getElementById('toast-container')) {
    const container = document.createElement('div');
    container.id = 'toast-container';
    document.body.appendChild(container);
  }

  const savedTheme = localStorage.getItem('theme');
  if (savedTheme === 'light') {
    document.body.classList.add('light-mode');
  }

  // Ensure DOM is parsed before updating icon
  setTimeout(() => {
    this.updateThemeIcon(savedTheme === 'light');
  }, 50);

  if (this.auth.token) {
    try {
      await this.auth.refresh();
    } catch (e) {
      console.warn("Session expired or refresh failed:", e);
      // Optional: redirect to login if refresh fails
    }
    await this.fetchFollowing();
  }
@@TwitterApp.init.end

@TwitterApp.toggleTheme{}: void
@@TwitterApp.toggleTheme.code
  document.body.classList.toggle('light-mode');
  const isLight = document.body.classList.contains('light-mode');
  localStorage.setItem('theme', isLight ? 'light' : 'dark');
  this.updateThemeIcon(isLight);
@@TwitterApp.toggleTheme.end

@TwitterApp.updateThemeIcon{isLight: boolean}: void
@@TwitterApp.updateThemeIcon.code
  const moon = document.getElementById('theme-icon-moon');
  const sun = document.getElementById('theme-icon-sun');
  if (moon && sun) {
      moon.style.display = isLight ? 'none' : 'block';
      sun.style.display = isLight ? 'block' : 'none';
  }
@@TwitterApp.updateThemeIcon.end

@async @TwitterApp.renderTimeline{containerId: string}: void
@@TwitterApp.renderTimeline.code
  await this.loadTimeline(containerId, false);
@@TwitterApp.renderTimeline.end

@async @TwitterApp.renderThread{containerId: string, tweetId: string}: void
@@TwitterApp.renderThread.code
    const container = document.getElementById(containerId);
    if (!container) return;
    
    container.innerHTML = "<div class='loading'>Loading conversation...</div>";

    try {
      const tweet = await this.feed.getTweet(tweetId);
      const replies = await this.feed.getReplies(tweetId);
      
      let html = this.renderSingleTweet(tweet);
      
      if (replies.length > 0) {
        html += "<div class='thread-replies' style='margin-top: 20px; border-top: 2px solid var(--border-color); padding-top: 20px;'>";
        html += "<h3 class='timeline-header'>Replies</h3>";
        replies.forEach(r => {
          html += this.renderSingleReply(r);
        });
        html += "</div>";
      } else {
        html += "<div class='empty-timeline' style='margin-top: 20px;'>No replies yet.</div>";
      }
      
      container.innerHTML = html;
      
      // Auto-expand the main tweet's view count
      this.feed.viewMessage(tweetId).catch(e => console.error(e));
      
    } catch (e) {
      this.showToast(e.message, 'error');
      container.innerHTML = "<div class='error'>Failed to load message: " + e.message + "</div>";
    }
@@TwitterApp.renderThread.end

@async @TwitterApp.renderUserTimeline{containerId: string, username: string, append: boolean}: void
@@TwitterApp.renderUserTimeline.code
    const container = document.getElementById(containerId);
    if (!container) return;
    
    if (!append) {
      this.profileTweetsOffset = 0;
      container.innerHTML = "<div class='loading'>Loading timeline...</div>";
    }

    try {
      const tweets = await this.feed.getUserTweets(username, this.tweetsLimit, this.profileTweetsOffset); 
      
      if (!append) container.innerHTML = "";
      
      if (tweets.length === 0) {
        if (!append) {
          container.innerHTML = "<div class='empty-timeline'>No messages yet.</div>";
        } else {
          this.showToast("No more messages", "info");
        }
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        if (loadMoreBtn) loadMoreBtn.style.display = 'none';
        return;
      }

      let html = "";
      for (const t of tweets) {
        html += this.renderSingleTweet(t);
      }
      
      if (append) {
        container.innerHTML += html;
      } else {
        container.innerHTML = html;
      }
      
      this.profileTweetsOffset += tweets.length;
      
      // Update Load More button
      const loadMoreBtn = document.getElementById('loadMoreBtn');
      if (loadMoreBtn) {
        loadMoreBtn.style.display = tweets.length < this.tweetsLimit ? 'none' : 'block';
        loadMoreBtn.onclick = () => this.renderUserTimeline(containerId, username, true);
      }
    } catch (e) {
      this.showToast(e.message, 'error');
    }
@@TwitterApp.renderUserTimeline.end

@async @TwitterApp.getUserInfo{username: string}: any
@@TwitterApp.getUserInfo.code
    const res = await fetch("http://localhost:8080/api/user?username=" + username);
    if (!res.ok) throw new Error("User not found");
    return await res.json();
@@TwitterApp.getUserInfo.end

  @async @TwitterApp.renderTrending{containerId: string}: void
  @@TwitterApp.renderTrending.code
    const container = document.getElementById(containerId);
    if (!container) return;

    try {
      let html = "";
      
      const trending = await this.feed.getTrending();
      if (trending && trending.length > 0) {
        html += "<h3>Trends for you</h3>";
        trending.forEach(t => {
          html += 
            "<div class='trending-item' onclick='window.location.href=\"dashboard.html?hashtag=" + t.tag + "\"'>" +
              "<div class='trending-tag'>#" + t.tag + "</div>" +
              "<div class='trending-count'>" + t.count + " Tweets</div>" +
            "</div>";
        });
      }

      const trendingLikes = await this.feed.getTrendingLikes();
      if (trendingLikes && trendingLikes.length > 0) {
        html += "<h3 style='margin-top: 20px;'>Trending Likes</h3>";
        trendingLikes.forEach(t => {
          const contentSnippet = t.content.length > 50 ? t.content.substring(0, 50) + "..." : t.content;
          html += 
            "<div class='trending-item' onclick=\"window.location.href='profile.html?username=" + t.authorUsername + "'\">" +
              "<div class='trending-tag'>@" + t.authorUsername + "</div>" +
              "<div class='trending-count' style='white-space: normal; margin-top: 4px;'>" + contentSnippet + "</div>" +
              "<div style='font-size: 0.8em; margin-top: 6px; font-weight: bold; color: var(--text-primary);'><svg viewBox='0 0 24 24' width='14' height='14' fill='#e0245e' stroke='none' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z'></path></svg>" + t.likedCount + " Likes</div>" +
            "</div>";
        });
      }

      if (html === "") {
        container.style.display = 'none';
      } else {
        container.style.display = 'block';
        container.innerHTML = html;
      }
    } catch (e) {
      console.error("Failed to render trending:", e);
      container.style.display = 'none';
    }
  @@TwitterApp.renderTrending.end

  @async @TwitterApp.performSearch{query: string, append: boolean}: void
  @@TwitterApp.performSearch.code
    if (!query) return;
    const container = document.getElementById('search-list');
    if (!container) return;

    if (!append || this.currentSearchQuery !== query) {
      this.searchOffset = 0;
      this.currentSearchQuery = query;
      container.innerHTML = "<div class='loading'>Searching...</div>";
    }

    try {
      const results = await this.feed.search(query, this.tweetsLimit, this.searchOffset);
      
      if (!append) container.innerHTML = "";

      if (results.length === 0) {
        if (!append) {
          container.innerHTML = "<div class='empty-timeline'>No results found for \"" + query + "\"</div>";
        } else {
          this.showToast("No more results", "info");
        }
        const loadMoreBtn = document.getElementById('searchLoadMoreBtn');
        if (loadMoreBtn) loadMoreBtn.style.display = 'none';
        return;
      }

      let html = "";
      results.forEach(r => {
        if (r.type === 'user') {
          html += this.renderUserItem(r, 'search');
        } else if (r.type === 'hashtag') {
          html += 
            "<div class='trending-item' style='margin-bottom: 10px; cursor: pointer;' onclick='window.app.showHashtagTimeline(\"" + r.tag + "\")'>" +
              "<div class='trending-tag' style='font-size: 1.1em;'>#" + r.tag + "</div>" +
              "<div class='trending-count' style='color: var(--text-secondary);'>" + r.count + " Tweets</div>" +
            "</div>";
        } else if (r.type === 'message') {
          html += this.renderSingleTweet({
             id: r.id, 
             authorUsername: r.sender_username, 
             authorName: r.sender_name, 
             authorAvatar: r.sender_avatar, 
             content: r.content, 
             timestamp: r.timestamp,
             repliedToId: r.repliedToId, 
             retweetedId: r.retweetedId,
             likedCount: r.likedCount,
             retweetCount: r.retweetCount, 
             repliesCount: r.repliesCount,
             imageUrl: r.imageUrl
          });
        }
      });

      if (append) {
        container.innerHTML += html;
      } else {
        container.innerHTML = html;
      }

      this.searchOffset += results.length;

      const loadMoreBtn = document.getElementById('searchLoadMoreBtn');
      if (loadMoreBtn) {
        loadMoreBtn.style.display = results.length < this.tweetsLimit ? 'none' : 'block';
        loadMoreBtn.onclick = () => this.performSearch(this.currentSearchQuery, true);
      }
    } catch (e) {
      console.error("Search failed:", e);
      this.showToast("Search failed: " + e.message, "error");
      if (!append) container.innerHTML = "<div class='error'>Failed to load search results.</div>";
    }
  @@TwitterApp.performSearch.end

  @async @TwitterApp.renderNotifications{containerId: string, append: boolean}: void
  @@TwitterApp.renderNotifications.code
    const container = document.getElementById(containerId);
    if (!container) return;

    if (!append) {
      this.notificationsOffset = 0;
      container.innerHTML = "<div class='loading'>Loading notifications...</div>";
    }

    try {
      const notifications = await this.feed.getNotifications(this.tweetsLimit, this.notificationsOffset);
      
      if (!append) container.innerHTML = "";

      if (!notifications || notifications.length === 0) {
        if (!append) {
          container.innerHTML = "<div class='empty-notifications'>No notifications yet.</div>";
        } else {
          this.showToast("No more notifications", "info");
        }
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        if (loadMoreBtn) loadMoreBtn.style.display = 'none';
        return;
      }

      let html = (!append ? "<h3>Notifications</h3>" : "");
      notifications.forEach(n => {
        const time = this.formatRelativeTime(n.timestamp);
        let actionText = "";
        let icon = "";
        if (n.action === 'like') { actionText = "liked your message"; icon = "<svg viewBox='0 0 24 24' width='16' height='16' fill='#e0245e' stroke='none' style='vertical-align: text-bottom;'><path d='M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z'></path></svg>"; }
        else if (n.action === 'follow') { actionText = "followed you"; icon = "<svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom;'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'></path><circle cx='12' cy='7' r='4'></circle></svg>"; }
        else if (n.action === 'retweet') { actionText = "reposted your message"; icon = "<svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='#17bf63' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom;'><path d='M17 1l4 4-4 4'></path><path d='M3 11V9a4 4 0 0 1 4-4h14'></path><path d='M7 23l-4-4 4-4'></path><path d='M21 13v2a4 4 0 0 1-4 4H3'></path></svg>"; }
        else if (n.action === 'reply') { actionText = "replied to your message"; icon = "<svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom;'><path d='M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.1a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z'></path></svg>"; }
        else if (n.action === 'mention') { actionText = "mentioned you"; icon = "<svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom;'><path d='M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9'></path><path d='M13.73 21a2 2 0 0 1-3.46 0'></path></svg>"; }

        html += 
          "<div class='notification-item " + (n.isRead ? "" : "unread") + "' id='notification-" + n.id + "'>" +
            "<img src='" + (n.fromAvatar || 'http://localhost:8080/images/userprofiledefault.png') + "' alt='Notification avatar' class='notification-avatar'>" +
            "<div class='notification-content'>" +
              "<div><a href='profile.html?username=" + n.from + "' class='notification-user'>@" + n.from + "</a> " + actionText + " " + icon + "</div>" +
              (n.parentContent ? "<div class='notification-parent-preview' style='font-size: 0.85em; opacity: 0.6; margin: 4px 0; padding-left: 8px; border-left: 2px solid var(--border-color); margin-top: 4px; font-style: italic;'>Replying to: \"" + n.parentContent + "\"</div>" : "") +
              (n.messageContent ? "<div class='notification-message-preview'>\"" + n.messageContent + "\"</div>" : "") +
              "<div class='notification-time'>" + time + "</div>" +
              "<div class='notification-actions' style='margin-top: 8px; display: flex; gap: 10px;'>" +
                ((n.action === 'reply' || n.action === 'mention') ? "<button class='btn btn-outline btn-compact' onclick=\"window.app.startReply('" + n.messageId + "', '" + n.from + "', 'notif-" + n.id + "')\"> Reply Back</button>" : "") +
                (n.action === 'follow' && !this.followedUsers.has(n.from) ? "<button class='btn btn-primary btn-compact' id='follow-back-" + n.from + "' style='width:auto;' onclick=\"window.app.toggleFollow('" + n.from + "', 0)\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'></path><circle cx='12' cy='7' r='4'></circle></svg> Follow Back</button>" : "") +
              "</div>" +
              "<div id='replies-instance-notif-" + n.id + "' class='replies-container' style='display: none;'></div>" +
            "</div>" +
          "</div>";
      });
      
      if (append) {
        container.innerHTML += html;
      } else {
        container.innerHTML = html;
        // Mark as read immediately when viewed (only on initial load)
        this.feed.markNotificationsRead();
        const navBadge = document.getElementById('notifications-badge');
        if (navBadge) navBadge.style.display = 'none';
      }

      this.notificationsOffset += notifications.length;
      
      // Update Load More button
      const loadMoreBtn = document.getElementById('loadMoreBtn');
      if (loadMoreBtn) {
        loadMoreBtn.style.display = notifications.length < this.tweetsLimit ? 'none' : 'block';
        loadMoreBtn.onclick = () => this.renderNotifications(containerId, true);
      }
    } catch (e) {
      console.error("Failed to render notifications:", e);
      this.showToast("Error loading notifications", "error");
    }
  @@TwitterApp.renderNotifications.end

  @async @TwitterApp.checkNotifications{}: void
  @@TwitterApp.checkNotifications.code
    try {
      const notifications = await this.feed.getNotifications();
      const unreadCount = notifications.filter(n => !n.isRead).length;
      const navBadge = document.getElementById('notifications-badge');
      if (navBadge) {
        if (unreadCount > 0) {
          navBadge.innerText = unreadCount > 9 ? "9+" : unreadCount;
          navBadge.style.display = 'block';
        } else {
          navBadge.style.display = 'none';
        }
      }
    } catch (e) {
      console.error("Failed to check notifications:", e);
    }
  @@TwitterApp.checkNotifications.end

@async @TwitterApp.loadTimeline{containerId: string, append: boolean}: void
@@TwitterApp.loadTimeline.code
  const container = document.getElementById(containerId);
  if (!container) return;
  
  if (!append) {
    this.tweetsOffset = 0;
    container.innerHTML = '';
  }
  
  const tweets = await this.feed.getTimeline(this.tweetsLimit, this.tweetsOffset);
  
  if (tweets.length === 0) {
    if (append) {
      this.showToast("No more messages to load", "info");
      const loadMoreBtn = document.getElementById('loadMoreBtn');
      if (loadMoreBtn) loadMoreBtn.style.display = 'none';
    } else {
      container.innerHTML = '<div style="padding: 20px; text-align: center; color: var(--text-secondary);">No messages yet!</div>';
    }
    return;
  }
  
  let html = '';
  tweets.forEach(t => {
    html += this.renderSingleTweet(t);
  });
  
  if (append) {
    container.innerHTML += html;
  } else {
    container.innerHTML = html;
  }
  
  this.tweetsOffset += tweets.length;
  
  // Show/Hide load more button based on if we got a full page
  const loadMoreBtn = document.getElementById('loadMoreBtn');
  if (loadMoreBtn) {
    loadMoreBtn.style.display = tweets.length < this.tweetsLimit ? 'none' : 'block';
    loadMoreBtn.onclick = () => this.loadMore(containerId);
  }
@@TwitterApp.loadTimeline.end

@async @TwitterApp.loadMore{containerId: string}: void
@@TwitterApp.loadMore.code
  await this.loadTimeline(containerId, true);
@@TwitterApp.loadMore.end

@TwitterApp.renderSingleTweet{t: any}: string
@@TwitterApp.renderSingleTweet.code
  const instanceId = ++this.renderCount;
  const name = t.authorName || t.authorUsername;
  const isRetweet = !!t.retweetedId;
  const retweetTag = isRetweet ? "<span class=\"retweet-tag\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M17 1l4 4-4 4'></path><path d='M3 11V9a4 4 0 0 1 4-4h14'></path><path d='M7 23l-4-4 4-4'></path><path d='M21 13v2a4 4 0 0 1-4 4H3'></path></svg> Reposted from @" + t.retweetedAuthor + "</span>" : "";
    const currentUser = this.auth.getCurrentUser();
    const retweetBtn = (t.authorUsername !== this.auth.currentUser?.username) ? 
    "<button class=\"tweet-btn retweet-btn\" id=\"retweet-btn-instance-" + instanceId + "\" onclick=\"window.app.retweet('" + t.id + "', " + instanceId + ")\"><svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M17 1l4 4-4 4'></path><path d='M3 11V9a4 4 0 0 1 4-4h14'></path><path d='M7 23l-4-4 4-4'></path><path d='M21 13v2a4 4 0 0 1-4 4H3'></path></svg> <span class='retweet-count'>" + (t.retweetCount || 0) + "</span></button>" : "";
    
    const avatarUrl = t.authorAvatar || 'http://localhost:8080/images/userprofiledefault.png';
    const avatarHtml = "<a href=\"profile.html?username=" + t.authorUsername + "\"><img src=\"" + avatarUrl + "\" alt=\"" + t.authorUsername + "'s avatar\" class=\"tweet-avatar\"></a>";
    const imageHtml = t.imageUrl ? "<div class=\"tweet-image-container\"><img src=\"" + t.imageUrl + "\" alt=\"Tweet image\" class=\"tweet-image\"></div>" : "";

    const isFollowing = this.followedUsers.has(t.authorUsername);
    const isSelf = currentUser && currentUser.username === t.authorUsername;
    const followBtn = (!isSelf && currentUser) ? 
      "<button class=\"tweet-btn follow-btn\" id=\"twitter-follow-" + t.authorUsername + "\" onclick=\"window.app.toggleFollow('" + t.authorUsername + "', " + (t.authorFollowerCount || 0) + ")\">" + (isFollowing ? "Unfollow" : "Follow") + "</button>" : "";

    const highlightedContent = t.content.replace(/#(\w+)/g, '<span class="hashtag" onclick="event.stopPropagation(); window.app.showHashtagTimeline(\'$1\')">#$1</span>').replace(/@(\w+)/g, '<a href="profile.html?username=$1" class="tweet-name-link" style="color: var(--accent-color); text-decoration: none;" onclick="event.stopPropagation()">@$1</a>');
    const replyContextHtml = t.repliedToUsername ? 
      "<div class='tweet-reply-context' style='margin-bottom: 8px; font-size: 0.9em;'>" +
        "<span style='color: var(--text-secondary);'>Replying to </span>" +
        "<a href='profile.html?username=" + t.repliedToUsername + "' class='tweet-name-link' style='color: var(--primary-color); font-weight: bold;'>@" + t.repliedToUsername + "</a>" +
        (t.parentContent ? "<div class='tweet-parent-preview'>\"" + t.parentContent + "\"</div>" : "") +
      "</div>" : "";

    return "<div class=\"tweet\" id=\"tweet-instance-" + instanceId + "\">" +
    "<div class=\"tweet-header\">" +
    avatarHtml +
    "<div class=\"tweet-header-info\">" +
    "<div class=\"tweet-header-top\">" +
    "<a href=\"profile.html?username=" + t.authorUsername + "\" class=\"tweet-name-link\"><span class=\"tweet-name\">" + name + "</span></a>" +
    "<a href=\"profile.html?username=" + t.authorUsername + "\" style=\"text-decoration:none; color:inherit;\"><span class=\"tweet-username\">@" + t.authorUsername + "</span></a>" +
    "<span class=\"tweet-username\">· " + this.formatRelativeTime(t.timestamp) + "</span>" +
    "<span class=\"tweet-followers\" id=\"followers-count-" + instanceId + "\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'></path><circle cx='12' cy='7' r='4'></circle></svg> <span>" + (t.authorFollowerCount || 0) + "</span></span>" +
    "</div>" +
    retweetTag +
    "</div>" +
    followBtn +
    "</div>" +
    "<div class=\"tweet-content\">" + replyContextHtml + highlightedContent + "</div>" +
    imageHtml +
    "<div class=\"tweet-footer\">" +
        "<button class=\"tweet-btn reply-btn\" onclick=\"window.app.startReply('" + t.id + "', '" + t.authorUsername + "', " + instanceId + ")\"><svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.1a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z'></path></svg> <span class='reply-count'>" + (t.repliesCount || 0) + "</span></button>" +
        retweetBtn +
        "<button class=\"tweet-btn like-btn\" id=\"like-btn-instance-" + instanceId + "\" onclick=\"window.app.like('" + t.id + "', " + instanceId + ")\"><svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom;'><path d='M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z'></path></svg> <span class='like-count'>" + (t.likedCount || 0) + "</span></button>" +
        "<span class=\"tweet-btn view-count-label\" id=\"view-count-instance-" + instanceId + "\"><svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><line x1='18' y1='20' x2='18' y2='10'></line><line x1='12' y1='20' x2='12' y2='4'></line><line x1='6' y1='20' x2='6' y2='14'></line></svg> <span class='view-count'>" + (t.viewCount || 0) + "</span></span>" +
        "<button class=\"tweet-btn view-replies-btn\" onclick=\"window.app.toggleReplies('" + t.id + "', " + instanceId + ", '" + t.authorUsername + "')\">View Replies</button>" +
        "<a href=\"message.html?id=" + t.id + "\" class=\"tweet-btn view-thread-btn\" style=\"text-decoration: none; display: inline-flex; align-items: center;\"><svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.1a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z'></path></svg> View Conversation</a>" +
        "<button class=\"tweet-btn report-btn\" onclick=\"window.app.reportTweet('" + t.id + "', " + instanceId + ")\"><svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z'></path><line x1='4' y1='22' x2='4' y2='15'></line></svg> Report</button>" +
      "</div>" +
      "<div id=\"replies-instance-" + instanceId + "\" class=\"replies-container\" style=\"display: none;\"></div>" +
    "</div>";
@@TwitterApp.renderSingleTweet.end

@TwitterApp.renderSingleReply{r: any}: string
@@TwitterApp.renderSingleReply.code
  const rInstanceId = ++this.renderCount;
    const currentUser = this.auth.getCurrentUser();
    const retweetBtn = (r.sender_username !== this.auth.currentUser?.username) ? 
    "<button class=\"tweet-btn retweet-btn btn-compact\" onclick=\"window.app.retweet('" + r.id + "', " + rInstanceId + ")\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M17 1l4 4-4 4'></path><path d='M3 11V9a4 4 0 0 1 4-4h14'></path><path d='M7 23l-4-4 4-4'></path><path d='M21 13v2a4 4 0 0 1-4 4H3'></path></svg> <span class='retweet-count'>" + (r.retweetCount || 0) + "</span></button>" : "";

    const avatarUrl = r.authorAvatar || 'http://localhost:8080/images/userprofiledefault.png';
    const avatarHtml = "<a href=\"profile.html?username=" + r.sender_username + "\"><img src=\"" + avatarUrl + "\" alt=\"" + r.sender_username + "'s avatar\" class=\"tweet-avatar\"></a>";
    const imageHtml = r.imageUrl ? "<div class=\"tweet-image-container\"><img src=\"" + r.imageUrl + "\" alt=\"Reply image\" class=\"tweet-image\"></div>" : "";

    const highlightedContent = r.content.replace(/#(\w+)/g, '<span class="hashtag" onclick="event.stopPropagation(); window.app.showHashtagTimeline(\'$1\')">#$1</span>').replace(/@(\w+)/g, '<a href="profile.html?username=$1" class="tweet-name-link" style="color: var(--accent-color); text-decoration: none;" onclick="event.stopPropagation()">@$1</a>');
    const replyContextHtml = r.repliedToUsername ? 
      "<div class='tweet-reply-context' style='margin-bottom: 5px; font-size: 0.8em; opacity: 0.8;'>" +
        "<span>Replying to </span>" +
        "<a href='profile.html?username=" + r.repliedToUsername + "' style='color: var(--primary-color); text-decoration: none;'>@" + r.repliedToUsername + "</a>" +
        (r.parentContent ? "<div style='opacity: 0.6; padding-left: 8px; border-left: 1px solid var(--border-color); margin-top: 2px;'>\"" + r.parentContent + "\"</div>" : "") +
      "</div>" : "";

    return "<div class=\"reply\" id=\"tweet-instance-" + rInstanceId + "\">" +
    "<div class=\"reply-header\"><div class=\"reply-header-info\">" + avatarHtml + "<a href=\"profile.html?username=" + r.sender_username + "\"><span>@" + r.sender_username + "</span></a><span class=\"tweet-date\">· " + this.formatRelativeTime(r.timestamp) + "</span></div></div>" +
    "<div class=\"reply-content\">" + replyContextHtml + highlightedContent + "</div>" +
    imageHtml +
    "<div class=\"reply-footer\">" +
      "<button class=\"tweet-btn reply-btn btn-compact\" onclick=\"window.app.startReply('" + r.id + "', '" + r.sender_username + "', " + rInstanceId + ")\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><path d='M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.1a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z'></path></svg> <span class='reply-count'>" + (r.repliesCount || 0) + "</span></button>" +
      retweetBtn +
      "<button class=\"tweet-btn like-btn btn-compact\" id=\"like-btn-instance-" + rInstanceId + "\" onclick=\"window.app.like('" + r.id + "', " + rInstanceId + ")\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom;'><path d='M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z'></path></svg> <span class='like-count'>" + (r.likedCount || 0) + "</span></button>" +
      "<span class=\"tweet-btn view-count-label btn-compact\" id=\"view-count-instance-" + rInstanceId + "\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom; margin-right: 4px;'><line x1='18' y1='20' x2='18' y2='10'></line><line x1='12' y1='20' x2='12' y2='4'></line><line x1='6' y1='20' x2='6' y2='14'></line></svg> <span class='view-count'>" + (r.viewCount || 0) + "</span></span>" +
      "<button class=\"tweet-btn view-replies-btn btn-compact\" onclick=\"window.app.toggleReplies('" + r.id + "', " + rInstanceId + ", '" + r.sender_username + "')\">View Replies</button>" +
      "<a href=\"message.html?id=" + r.id + "\" class=\"tweet-btn view-thread-btn btn-compact\" style=\"text-decoration: none; display: inline-flex; align-items: center;\" title=\"View Conversation\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom;'><path d='M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.1a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z'></path></svg></a>" +
      "<button class=\"tweet-btn report-btn btn-compact\" title=\"Report\" onclick=\"window.app.reportTweet('" + r.id + "', " + rInstanceId + ")\"><svg viewBox='0 0 24 24' width='14' height='14' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='vertical-align: text-bottom;'><path d='M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z'></path><line x1='4' y1='22' x2='4' y2='15'></line></svg></button>" +
    "</div>" +
    "<div id=\"replies-instance-" + rInstanceId + "\" class=\"replies-container\" style=\"display: none;\"></div>" +
  "</div>";
@@TwitterApp.renderSingleReply.end

@async @TwitterApp.showHashtagTimeline{tag: string}: void
@@TwitterApp.showHashtagTimeline.code
  this.currentTag = tag;
  this.tweetsOffset = 0;
  document.getElementById('search-container').style.display = 'none';
  document.getElementById('searchInput').value = '';
  document.getElementById('timeline-container').style.display = 'block';
  await window.app.loadTimeline('timeline', false);
  const container = document.getElementById('timeline');
  if (container) {
    container.innerHTML = 
      "<div class=\"trend-header\">" +
        "<span>Watching trends: <span class=\"trend-tag\">#" + tag + "</span></span>" +
        "<button class=\"tweet-btn back-btn\" onclick=\"window.app.goBackToTimeline()\">Go back to timeline</button>" +
      "</div>" +
      "<div id=\"hashtag-timeline-content\"></div>";
    
    await this.loadHashtagTimeline(tag, false);
    
    // Update Load More button behavior
    const loadMoreBtn = document.getElementById('loadMoreBtn');
    if (loadMoreBtn) {
       loadMoreBtn.onclick = () => window.app.loadHashtagTimeline(tag, true);
    }
  } else {
    // If not on dashboard, redirect to dashboard with hashtag param
    window.location.href = 'dashboard.html?hashtag=' + encodeURIComponent(tag);
  }
@@TwitterApp.showHashtagTimeline.end

@async @TwitterApp.goBackToTimeline{}: void
@@TwitterApp.goBackToTimeline.code
  this.currentTag = null;
  this.tweetsOffset = 0;
  const container = document.getElementById('timeline');
  if (container) {
    container.innerHTML = '';
    // Re-bind loadMoreBtn to default
    const loadMoreBtn = document.getElementById('loadMoreBtn');
    if (loadMoreBtn) {
       loadMoreBtn.onclick = () => window.app.loadMore('timeline');
    }
    await this.renderTimeline('timeline');
    window.history.replaceState('dashboard', 'dashboard', '/dashboard.html');

  }
@@TwitterApp.goBackToTimeline.end

@async @TwitterApp.loadHashtagTimeline{tag: string, append: boolean}: void
@@TwitterApp.loadHashtagTimeline.code
  const container = document.getElementById('hashtag-timeline-content');
  if (!container) return;
  
  if (!append) {
    this.tweetsOffset = 0;
    container.innerHTML = '';
  }
  
  const tweets = await this.feed.getHashtagFeed(tag, this.tweetsLimit, this.tweetsOffset);
  
  if (tweets.length === 0) {
    if (!append) {
      container.innerHTML = '<div style="padding: 20px; text-align: center; color: var(--text-secondary);">No tweets found for #' + tag + '</div>';
    } else {
      this.showToast("No more tweets to load", "info");
      const loadMoreBtn = document.getElementById('loadMoreBtn');
      if (loadMoreBtn) loadMoreBtn.style.display = 'none';
    }
    return;
  }
  
  let html = '';
  tweets.forEach(t => {
    html += this.renderSingleTweet(t);
  });
  
  if (append) {
    container.innerHTML += html;
  } else {
    container.innerHTML = html;
  }
  
  this.tweetsOffset += tweets.length;
  
  const loadMoreBtn = document.getElementById('loadMoreBtn');
  if (loadMoreBtn) {
    loadMoreBtn.style.display = tweets.length < this.tweetsLimit ? 'none' : 'block';
    loadMoreBtn.onclick = () => this.loadHashtagTimeline(tag, true);
  }
@@TwitterApp.loadHashtagTimeline.end

@TwitterApp.formatRelativeTime{timestamp: number}: string
@@TwitterApp.formatRelativeTime.code
  if (!timestamp) return "just now";
  const now = Date.now();
  const diff = now - timestamp;
  if (diff < 0) return "just now";
  
  const seconds = Math.floor(diff / 1000);
  const minutes = Math.floor(seconds / 60);
  const hours = Math.floor(minutes / 60);
  const days = Math.floor(hours / 24);
  const weeks = Math.floor(days / 7);
  const months = Math.floor(days / 30);
  const years = Math.floor(days / 365);

  if (seconds < 60) return "just now";
  if (minutes < 60) return minutes + "m ago";
  if (hours < 24) return hours + "h ago";
  if (days < 7) return days + "d ago";
  if (weeks < 4) return weeks + "w ago";
  if (months < 12) return months + "mo ago";
  return years + "y ago";
@@TwitterApp.formatRelativeTime.end

@async @TwitterApp.toggleReplies{tweetId: string, instanceId: number, authorUsername: string}: void
@@TwitterApp.toggleReplies.code
  const container = document.getElementById("replies-instance-" + instanceId);
  if (!container) return;
  
  if (container.style.display === 'block') {
    container.style.display = 'none';
    return;
  }
  
  this.feed.viewMessage(tweetId).then((res) => {
    // Only conditionally increment if current user is not author visually and it was their first time viewing
    if (res && res.incremented) {
       const viewElem = document.getElementById("view-count-instance-" + instanceId);
       if (viewElem) {
         const countSpan = viewElem.querySelector('.view-count');
         const current = countSpan ? (parseInt(countSpan.innerText) || 0) : 0;
         if (countSpan) countSpan.innerText = (current + 1);
      }
    }
  }).catch(e => console.error(e));

  const replies = await this.feed.getReplies(tweetId);

  if (replies.length === 0) {
    container.innerHTML = '<div style="padding: 10px; color: #888;">No replies yet</div>';
  } else {
    container.innerHTML = replies.map(r => this.renderSingleReply(r)).join('');
  }
  container.style.display = 'block';
@@TwitterApp.toggleReplies.end

@async @TwitterApp.postNewTweet{authorUsername: string, content: string, repliedToId: string, retweetedId: string, imageUrl: string}: any
@@TwitterApp.postNewTweet.code
  const res = await this.feed.postTweet(authorUsername, content, repliedToId, retweetedId, imageUrl);
  if (res) {
    this.showToast("Tweet posted!", "success");
  }
  return res;
@@TwitterApp.postNewTweet.end

@async @TwitterApp.updateAvatar{avatarUrl: string}: void
@@TwitterApp.updateAvatar.code
  const response = await fetch("http://localhost:8080/api/user/avatar", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + this.auth.token
    },
    body: JSON.stringify({ avatarUrl })
  });
  if (response.ok) {
    this.showToast("Avatar updated!", "success");
    // Update local user object
    const user = this.auth.getCurrentUser();
    if (user) {
        user.avatarUrl = avatarUrl;
        localStorage.setItem('currentUser', JSON.stringify(user));
    }
    // Update sidebar if exists
    const sidebarAvatar = document.getElementById('sidebar-avatar');
    if (sidebarAvatar) sidebarAvatar.src = avatarUrl;
  } else {
    this.showToast("Failed to update avatar", "error");
  }
@@TwitterApp.updateAvatar.end

@async @TwitterApp.updateBanner{bannerUrl: string}: void
@@TwitterApp.updateBanner.code
  const response = await fetch("http://localhost:8080/api/user/banner", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + this.auth.token
    },
    body: JSON.stringify({ bannerUrl })
  });
  if (response.ok) {
    this.showToast("Banner updated!", "success");
    // Update local user object
    const user = this.auth.getCurrentUser();
    if (user) {
        user.banner_url = bannerUrl;
        localStorage.setItem('currentUser', JSON.stringify(user));
    }
    const bannerElem = document.getElementById('profile-banner');
    if (bannerElem) {
        bannerElem.style.backgroundImage = "url('" + bannerUrl + "')";
        bannerElem.classList.remove('profile-banner-placeholder');
    }
  } else {
    this.showToast("Failed to update banner", "error");
  }
@@TwitterApp.updateBanner.end

@TwitterApp.startReply{tweetId: string, author: string, instanceId: string}: void
@@TwitterApp.startReply.code
  const container = document.getElementById("replies-instance-" + instanceId);
  if (!container) return;
  
  if (container.style.display === 'none') {
    container.style.display = 'block';
  }
  
  const inputId = "reply-input-instance-" + instanceId;
  if (!document.getElementById(inputId)) {
    const inputDiv = document.createElement('div');
    inputDiv.id = inputId;
    inputDiv.className = "inline-reply-div";
    inputDiv.innerHTML = 
      "<textarea id=\"input-instance-" + instanceId + "\" class=\"inline-reply-textarea\" placeholder=\"Replying to @" + author + "...\" maxlength=\"300\"></textarea>" +
      "<div id=\"image-preview-instance-" + instanceId + "\" style=\"display: none; margin-bottom: 10px; position: relative;\">" +
        "<img id=\"preview-img-instance-" + instanceId + "\" src=\"\" alt=\"Image Preview\" style=\"max-width: 100%; border-radius: var(--radius-md);\">" +
        "<button id=\"remove-img-btn-instance-" + instanceId + "\" class=\"btn\" style=\"position: absolute; top: 10px; right: 10px; width: 30px; height: 30px; border-radius: 50%; padding: 0; background: rgba(0,0,0,0.6); color: white; display: flex; align-items: center; justify-content: center;\"><svg viewBox='0 0 24 24' width='18' height='18' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><line x1='18' y1='6' x2='6' y2='18'></line><line x1='6' y1='6' x2='18' y2='18'></line></svg></button>" +
      "</div>" +
      "<div class=\"inline-reply-actions\">" +
        "<input type=\"file\" id=\"img-input-instance-" + instanceId + "\" accept=\"image/png, image/jpeg\" style=\"display: none;\">" +
        "<div id=\"reply-char-count-" + instanceId + "\" class=\"char-counter\">0 / 300</div>" +
        "<button id=\"add-img-btn-instance-" + instanceId + "\" class=\"add-image-btn btn btn-outline\" style=\"display: inline-flex; align-items: center;\"><svg viewBox='0 0 24 24' width='16' height='16' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' style='margin-right: 4px;'><rect x='3' y='3' width='18' height='18' rx='2' ry='2'></rect><circle cx='8.5' cy='8.5' r='1.5'></circle><polyline points='21 15 16 10 5 21'></polyline></svg> Image</button>" +
        "<button class=\"btn btn-primary\" onclick=\"window.app.postInlineReply('" + tweetId + "', '" + instanceId + "', '" + author + "')\">Reply</button>" +
      "</div>";
    container.prepend(inputDiv);
    
    const replyInput = document.getElementById("input-instance-" + instanceId);
    const replyCounter = document.getElementById("reply-char-count-" + instanceId);
    replyInput.addEventListener('input', () => {
      const len = replyInput.value.length;
      replyCounter.innerText = len + " / 300";
      if (len >= 300) replyCounter.classList.add('limit-reached');
      else replyCounter.classList.remove('limit-reached');
    });
    
    const imgInput = document.getElementById("img-input-instance-" + instanceId);
    const addImgBtn = document.getElementById("add-img-btn-instance-" + instanceId);
    const previewContainer = document.getElementById("image-preview-instance-" + instanceId);
    const previewImg = document.getElementById("preview-img-instance-" + instanceId);
    const removeImgBtn = document.getElementById("remove-img-btn-instance-" + instanceId);

    addImgBtn.addEventListener("click", () => imgInput.click());

    imgInput.addEventListener("change", (e) => {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (re) => {
          window.app["_inlineImg_" + instanceId] = re.target.result;
          previewImg.src = re.target.result;
          previewContainer.style.display = "block";
        };
        reader.readAsDataURL(file);
      }
    });

    removeImgBtn.addEventListener("click", () => {
      window.app["_inlineImg_" + instanceId] = null;
      imgInput.value = "";
      previewContainer.style.display = "none";
    });
    
    replyInput.focus();
  } else {
    document.getElementById("input-instance-" + instanceId).focus();
  }
@@TwitterApp.startReply.end

@async @TwitterApp.postInlineReply{parentTweetId: string, instanceId: string, parentAuthor: string}: void
@@TwitterApp.postInlineReply.code
  const textarea = document.getElementById("input-instance-" + instanceId);
  const content = textarea.value;
  const base64Img = window.app["_inlineImg_" + instanceId];

  if (!content && !base64Img) return;
  
  const author = this.auth.currentUser.username;
  let imageUrl = '';
  if (base64Img) {
    try {
      const uploadRes = await this.feed.uploadImage(base64Img);
      imageUrl = uploadRes.url;
    } catch (e) {
      this.showToast(e.message, 'error');
      return;
    }
  }

  const res = await this.feed.postTweet(author, content, parentTweetId, '', imageUrl);
  window.app["_inlineImg_" + instanceId] = null;
  
  const inputDiv = document.getElementById("reply-input-instance-" + instanceId);
  if (inputDiv) inputDiv.remove();
  
  const container = document.getElementById("replies-instance-" + instanceId);
  const newReplyHtml = this.renderSingleReply({
    id: res.id,
    sender_username: author,
    content: content,
    timestamp: Date.now(),
    repliedToUsername: parentAuthor, // Add parent author for context
    parentContent: '', // We don't have parent content here, but it's good to include the field
    repliesCount: 0,
    retweetCount: 0,
    likedCount: 0,
    imageUrl: imageUrl,
    videoUrl: ''
  });
  
  if (container.innerHTML.includes('No replies yet')) {
    container.innerHTML = '';
  }
  const newReplyDiv = document.createElement('div');
  newReplyDiv.innerHTML = newReplyHtml;
  container.prepend(newReplyDiv.firstElementChild);
  this.showToast("Reply posted!", "success");
  
  const replyBtn = document.querySelector("#tweet-instance-" + instanceId + " .reply-btn");
  if (replyBtn) {
    const countSpan = replyBtn.querySelector('.reply-count');
    const current = countSpan ? (parseInt(countSpan.innerText) || 0) : 0;
    if (countSpan) countSpan.innerText = (current + 1).toString();
  }
@@TwitterApp.postInlineReply.end

@async @TwitterApp.like{tweetId: string, instanceId: number}: void
@@TwitterApp.like.code
  try {
    await this.feed.likeMessage(tweetId);
    const btnId = "like-btn-instance-" + instanceId;
    const btn = document.getElementById("like-btn-instance-" + instanceId);
    if (btn) {
      const countSpan = btn.querySelector('.like-count');
      const current = countSpan ? (parseInt(countSpan.innerText) || 0) : 0;
      if (countSpan) countSpan.innerText = (current + 1);
      
      const svg = btn.querySelector('svg');
      if (svg) {
          svg.setAttribute('fill', '#e0245e');
          svg.setAttribute('stroke', '#e0245e');
      }
      btn.classList.add('heart-pop');
      setTimeout(() => btn.classList.remove('heart-pop'), 400);
      
      this.showToast("Liked!", "success");
    }
  } catch (e) {
    this.showToast("Failed to like", "error");
  }
@@TwitterApp.like.end

@async @TwitterApp.retweet{tweetId: string, instanceId: number}: void
@@TwitterApp.retweet.code
  try {
    const result = await this.feed.retweetMessage(tweetId);
    
    if (!result.ok) {
      if (result.status === 409) {
        this.showToast("You've already retweeted this", "error");
      } else {
        this.showToast(result.data.error || "Failed to retweet", "error");
      }
      return;
    }

    const retweet = result.data;
    
    // Prepend to timeline
    const container = document.getElementById("timeline");
    if (container && retweet) {
      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = this.renderSingleTweet(retweet);
      if (tempDiv.firstElementChild) {
        container.prepend(tempDiv.firstElementChild);
        this.showToast("Reposted successfully!", "success");
      }
    }

    // Update original button count
    const btnId = "retweet-btn-instance-" + instanceId;
    const btn = document.getElementById(btnId);
    if (btn) {
      const countSpan = btn.querySelector('.retweet-count');
      const current = countSpan ? (parseInt(countSpan.innerText) || 0) : 0;
      if (countSpan) countSpan.innerText = (current + 1);
      
      const svg = btn.querySelector('svg');
      if (svg) {
          svg.setAttribute('stroke', '#17bf63');
      }
      btn.classList.add('heart-pop');
      setTimeout(() => btn.classList.remove('heart-pop'), 400);
    }
  } catch (e) {
    this.showToast("Connection error", "error");
  }
@@TwitterApp.retweet.end

@TwitterApp.showToast{message: string, type: string}: void
@@TwitterApp.showToast.code
  const container = document.getElementById('toast-container');
  if (!container) return;

  const toast = document.createElement('div');
  toast.className = "toast " + type;
  toast.innerText = message;
  container.appendChild(toast);

  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translate(-50%, 20px)';
    setTimeout(() => toast.remove(), 300);
  }, 3000);
@@TwitterApp.showToast.end

@async @TwitterApp.fetchFollowing{}: void
@@TwitterApp.fetchFollowing.code
  try {
    const list = await this.feed.getFollowing();
    this.followedUsers = new Set(list.map((u: any) => u.username));
  } catch (e) {
    console.error("Failed to fetch following list", e);
  }
@@TwitterApp.fetchFollowing.end

@async @TwitterApp.toggleFollow{username: string, currentCount: number}: void
@@TwitterApp.toggleFollow.code
  const isFollowing = this.followedUsers.has(username);
  
  try {
    if (isFollowing) {
      await this.feed.unfollowUser(username);
      this.followedUsers.delete(username);
      this.showToast("Unfollowed @" + username, "info");
    } else {
      await this.feed.followUser(username);
      this.followedUsers.add(username);
      this.showToast("Following @" + username, "success");
    }
    
    // Update all follow buttons for this user
    const buttons = document.querySelectorAll("[id='twitter-follow-" + username + "']");
    buttons.forEach((btn: any) => {
      btn.innerText = isFollowing ? "Follow" : "Unfollow";
    });

    // If we just followed, remove any 'Follow Back' buttons for this user
    if (!isFollowing) {
      const followBackBtns = document.querySelectorAll("[id='follow-back-" + username + "']");
      followBackBtns.forEach((btn: any) => btn.remove());
    }
    
    // Update local following count
    if (this.auth.currentUser) {
       const delta = isFollowing ? -1 : 1;
       this.auth.currentUser.followingCount = Math.max(0, (this.auth.currentUser.followingCount || 0) + delta);
       localStorage.setItem('currentUser', JSON.stringify(this.auth.currentUser));
       const followCountEl = document.getElementById('header-following-count');
       if (followCountEl) followCountEl.innerText = this.auth.currentUser.followingCount;
    }

    // Update all follower counts for this user on the screen
    const followerElements = document.querySelectorAll('.tweet-username');
    followerElements.forEach(el => {
      if (el.innerText === '@' + username) {
         const headerTop = el.closest('.tweet-header-top');
         if (headerTop) {
           const countContainer = headerTop.querySelector('.tweet-followers');
           if (countContainer) {
             const countSpan = countContainer.querySelector('span'); // target the inner span
             const current = countSpan ? (parseInt(countSpan.innerText) || 0) : 0;
             if (countSpan) countSpan.innerText = Math.max(0, (isFollowing ? current - 1 : current + 1)).toString();
           }
         }
      }
    });
 
    // If on social.html, refresh the list to show updated states and potentially new items
    if (window.location.pathname.includes('social.html') && this.currentSocialUser) {
        await this.renderSocialList('social-list', this.currentSocialUser, this.currentSocialType);
    }

  } catch (e) {
    this.showToast("Action failed: " + e.message, "error");
  }
@@TwitterApp.toggleFollow.end

@async @TwitterApp.renderSocialList{containerId: string, username: string, type: string}: void
@@TwitterApp.renderSocialList.code
    const container = document.getElementById(containerId);
    if (!container) return;
 
    this.currentSocialUser = username;
    this.currentSocialType = type;


    try {
      let users = [];
      if (type === 'followers') {
        users = await this.feed.getFollowers(username);
      } else {
        users = await this.feed.getFollowingList(username);
      }

      if (users.length === 0) {
        container.innerHTML = "<div class='empty-timeline'>No users found.</div>";
        return;
      }

      let html = "";
      users.forEach(u => {
        html += this.renderUserItem(u, type);
      });
      container.innerHTML = html;
    } catch (e) {
      this.showToast(e.message, 'error');
      container.innerHTML = "<div class='error'>Error loading list.</div>";
    }
@@TwitterApp.renderSocialList.end

@TwitterApp.renderUserItem{user: any, listType: string}: string
@@TwitterApp.renderUserItem.code
    const avatarUrl = user.avatarUrl || 'http://localhost:8080/images/userprofiledefault.png';
    const isFollowing = this.followedUsers.has(user.username);
    const currentUser = this.auth.getCurrentUser();
    const isSelf = currentUser && currentUser.username === user.username;
    
    let btnText = isFollowing ? "Unfollow" : "Follow";
    if (listType === 'followers' && !isFollowing) {
        btnText = "Follow Back";
    }

    const followBtn = (!isSelf && currentUser) ? 
      "<button class=\"btn " + (isFollowing ? "btn-outline" : "btn-primary") + " btn-compact\" style=\"width:auto;\" onclick=\"window.app.toggleFollow('" + user.username + "', 0)\">" + btnText + "</button>" : "";

    return "<div class='user-item'>" +
             "<a href='profile.html?username=" + user.username + "' class='user-item-link'>" +
               "<img src='" + avatarUrl + "' alt='" + user.username + "\\'s avatar' class='user-item-avatar'>" +
               "<div class='user-item-info'>" +
                 "<div class='user-item-name'>" + (user.name || user.username) + "</div>" +
                 "<div class='user-item-username'>@" + user.username + "</div>" +
               "</div>" +
             "</a>" +
             "<div class='user-item-actions'>" + followBtn + "</div>" +
           "</div>";
@@TwitterApp.renderUserItem.end

@async @TwitterApp.reportTweet{tweetId: string, instanceId: number}: void
@@TwitterApp.reportTweet.code
  if (!confirm("Are you sure you want to report this tweet?")) return;
  try {
    await this.feed.reportTweet(tweetId);
    this.showToast("Tweet reported to administrators", "success");
  } catch (e) {
    this.showToast("Failed to report tweet: " + e.message, "error");
  }
@@TwitterApp.reportTweet.end

