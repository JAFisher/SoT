include->authfe.flow

type->Tweet {id: string, authorUsername: string, content: string, timestamp: number}

Feed[Feed.ts{tweets: Array}]
Feed --> AuthFE

@Feed.constructor{}
@@Feed.constructor.code
  this.tweets = [];
@@Feed.constructor.end

@async @Feed.postTweet{senderUsername: string, content: string, repliedToId: string, retweetedId: string, imageUrl: string}: any
@@Feed.postTweet.code
  const response = await fetch("http://localhost:8080/api/tweets", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + window.app.auth.token
    },
    body: JSON.stringify({ senderUsername, content, repliedToId, retweetedId, imageUrl })
  });
  return await response.json();
@@Feed.postTweet.end

@async @Feed.likeMessage{messageId: string}: any
@@Feed.likeMessage.code
  const response = await fetch('http://localhost:8080/api/like', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + window.app.auth.token
    },
    body: JSON.stringify({ messageId })
  });
  if (!response.ok) throw new Error("Failed to like");
  return await response.json();
@@Feed.likeMessage.end

@async @Feed.unlikeMessage{messageId: string}: any
@@Feed.unlikeMessage.code
  const response = await fetch('http://localhost:8080/api/unlike', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + window.app.auth.token
    },
    body: JSON.stringify({ messageId })
  });
  if (!response.ok) throw new Error("Failed to unlike");
  return await response.json();
@@Feed.unlikeMessage.end

@async @Feed.retweetMessage{originalId: string}: any
@@Feed.retweetMessage.code
  const response = await fetch('http://localhost:8080/api/retweet', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + window.app.auth.token
    },
    body: JSON.stringify({ originalId })
  });
  
  const data = await response.json();
  return { ok: response.ok, status: response.status, data };
@@Feed.retweetMessage.end

@async @Feed.getTimeline{limit: number, offset: number}: any
@@Feed.getTimeline.code
  const l = limit || 10;
  const o = offset || 0;
  const res = await fetch("http://localhost:8080/api/tweets?limit=" + l + "&offset=" + o);
  return await res.json();
@@Feed.getTimeline.end
 
 @async @Feed.getHashtagFeed{tag: string, limit: number, offset: number}: any
 @@Feed.getHashtagFeed.code
   const l = limit || 10;
   const o = offset || 0;
   const res = await fetch("http://localhost:8080/api/tweets/hashtag?tag=" + encodeURIComponent(tag) + "&limit=" + l + "&offset=" + o);
   return await res.json();
 @@Feed.getHashtagFeed.end

@async @Feed.getUserTweets{username: string}: any
@@Feed.getUserTweets.code
  const response = await fetch('http://localhost:8080/api/tweets?username=' + username);
  if (!response.ok) throw new Error("Failed to fetch user tweets");
  return await response.json();
@@Feed.getUserTweets.end
@async @Feed.getReplies{messageId: string}: any
@@Feed.getReplies.code
  const response = await fetch('http://localhost:8080/api/replies?id=' + messageId);
  if (!response.ok) throw new Error("Failed to fetch replies");
  return await response.json();
@@Feed.getReplies.end

@async @Feed.uploadImage{base64Data: string}: any
@@Feed.uploadImage.code

 
  const response = await fetch("http://localhost:8080/api/upload", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + window.app.auth.token
    },
    body: JSON.stringify({ base64Data })
  });
  if (!response.ok) {
    const err = await response.json();
    throw new Error(err.error || "Upload failed");
  }
  return await response.json();
@@Feed.uploadImage.end
@async @Feed.followUser{username: string}: any
@@Feed.followUser.code
  const response = await fetch("http://localhost:8080/api/follow", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
