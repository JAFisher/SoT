cliscripts->build_docker docker build -t twitter-db .
cliscripts->start_docker docker run -p 5432:5432 twitter-db

docker->start
FROM postgres:latest
ENV POSTGRES_PASSWORD=mysecretpassword
EXPOSE 5432
docker->end

extern->pg from "pg"

Database[Database.ts{pool: any}]

@Database.constructor{}
@@Database.constructor.code
  this.pool = new pg.Pool({
    user: 'postgres',
    host: 'localhost',
    database: 'postgres',
    password: 'mysecretpassword',
    port: 5432,
  });
@@Database.constructor.end

@async @Database.init{}: void
@@Database.init.code


  await this.pool.query("CREATE TABLE IF NOT EXISTS users (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), username VARCHAR(255) UNIQUE NOT NULL, name VARCHAR(255) NOT NULL, password_hash VARCHAR(255) NOT NULL, avatar_url TEXT);");
  await this.pool.query("ALTER TABLE users ADD COLUMN IF NOT EXISTS follower_count INT DEFAULT 0;");
  await this.pool.query("ALTER TABLE users ADD COLUMN IF NOT EXISTS following_count INT DEFAULT 0;");
  await this.pool.query("ALTER TABLE users ADD COLUMN IF NOT EXISTS banner_url TEXT;");
  await this.pool.query("CREATE TABLE IF NOT EXISTS messages (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), sender_username VARCHAR(255) NOT NULL, receiver_username VARCHAR(255) NOT NULL,content TEXT NOT NULL,timestamp BIGINT NOT NULL,replied_to_id UUID,retweeted_id UUID,liked_count INT DEFAULT 0, retweet_count INT DEFAULT 0, image_url TEXT);");
  await this.pool.query("CREATE TABLE IF NOT EXISTS likes ( id SERIAL PRIMARY KEY, message_id UUID NOT NULL REFERENCES messages(id), username VARCHAR(255) NOT NULL, UNIQUE(message_id, username));");
  await this.pool.query("CREATE TABLE IF NOT EXISTS follows (follower_username VARCHAR(255) NOT NULL, following_username VARCHAR(255) NOT NULL, UNIQUE(follower_username, following_username));");
  await this.pool.query("CREATE TABLE IF NOT EXISTS hashtags (tag VARCHAR(255) NOT NULL, message_id UUID NOT NULL REFERENCES messages(id) ON DELETE CASCADE, PRIMARY KEY (tag, message_id));");
  await this.pool.query("CREATE TABLE IF NOT EXISTS notifications (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), sender_username VARCHAR(255) NOT NULL, receiver_username VARCHAR(255) NOT NULL, action VARCHAR(255) NOT NULL, message_id UUID, timestamp BIGINT NOT NULL, is_read BOOLEAN DEFAULT FALSE, UNIQUE(sender_username, receiver_username, action, message_id));");

  console.log("Database initialized (Fresh start).");
@@Database.init.end

@async @Database.insertMessage{senderUsername: string, receiverUsername: string, content: string, timestamp: number, repliedToId: string, retweetedId: string, imageUrl: string}: any
@@Database.insertMessage.code
  if (content && content.length > 300) {
    throw new Error("Message content exceeds 300 characters");
  }
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    const res = await client.query(
      "INSERT INTO messages (sender_username, receiver_username, content, timestamp, replied_to_id, retweeted_id, image_url) VALUES ($1, $2, $3, $4, $5, $6, $7) RETURNING *",
      [senderUsername, receiverUsername, content, timestamp, repliedToId || null, retweetedId || null, imageUrl || null]
    );
    const message = res.rows[0];
    
    // Extract hashtags
    const hashtags = content.match(/#(\w+)/g);
    if (hashtags) {
      for (const t of hashtags) {
        const tag = t.substring(1).toLowerCase();
        await client.query(
          "INSERT INTO hashtags (tag, message_id) VALUES ($1, $2) ON CONFLICT DO NOTHING",
          [tag, message.id]
        );
      }
    }
    
    // Notification for mentions
    const mentionMatches = content.match(/@(\w+)/g);
    if (mentionMatches) {
      const uniqueMentions = Array.from(new Set(mentionMatches.map(m => m.substring(1))));
      for (const mentionedUser of uniqueMentions) {
        if (mentionedUser !== senderUsername) {
          await client.query(
            "INSERT INTO notifications (sender_username, receiver_username, action, message_id, timestamp) VALUES ($1, $2, $3, $4, $5) ON CONFLICT DO NOTHING",
            [senderUsername, mentionedUser, 'mention', message.id, timestamp]
          );
        }
      }
    }
    // Notification for replies
    if (repliedToId) {
      const parentRes = await client.query("SELECT sender_username FROM messages WHERE id = $1", [repliedToId]);
      if (parentRes.rows.length > 0) {
        const parentOwner = parentRes.rows[0].sender_username;
        if (parentOwner !== senderUsername) {
           await client.query(
             "INSERT INTO notifications (sender_username, receiver_username, action, message_id, timestamp) VALUES ($1, $2, $3, $4, $5) ON CONFLICT DO NOTHING",
             [senderUsername, parentOwner, 'reply', message.id, timestamp]
           );
        }
      }
    }
    
    await client.query('COMMIT');
    return message;
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.insertMessage.end

@async @Database.getMessagesBetween{user1: string, user2: string}: any
@@Database.getMessagesBetween.code
  const res = await this.pool.query(
    "SELECT * FROM messages WHERE (sender_username = $1 AND receiver_username = $2) OR (sender_username = $2 AND receiver_username = $1) ORDER BY timestamp ASC",
    [user1, user2]
  );
  return res.rows.map(row => ({
    id: row.id,
    senderUsername: row.sender_username,
    receiverUsername: row.receiver_username,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    retweetedId: row.retweeted_id,
    likedCount: row.liked_count,
    retweetCount: row.retweet_count
  }));
@@Database.getMessagesBetween.end

@async @Database.getPublicTweets{limit: number, offset: number}: any
@@Database.getPublicTweets.code
  const l = limit || 10;
  const o = offset || 0;
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as retweeted_author, u1.avatar_url as author_avatar, u1.follower_count as author_follower_count, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "LEFT JOIN messages m2 ON m1.retweeted_id = m2.id " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "WHERE m1.receiver_username = '' " +
    "ORDER BY m1.timestamp DESC " +
    "LIMIT $1 OFFSET $2",
    [l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    authorUsername: row.sender_username,
    authorAvatar: row.author_avatar,
    authorFollowerCount: row.author_follower_count || 0,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    retweetedId: row.retweeted_id,
    retweetedAuthor: row.retweeted_author,
    likedCount: row.liked_count,
    retweetCount: row.retweet_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url
  }));
@@Database.getPublicTweets.end

@async @Database.getPersonalizedTweets{currentUser: string, limit: number, offset: number}: any
@@Database.getPersonalizedTweets.code
  const l = limit || 10;
  const o = offset || 0;
  // Weighting logic:
  // 1. Followed users get 3x higher base weight
  // 2. Higher follower count increases weight (logarithmic scale)
  // 3. Score = weight * timestamp (keeps it chronological-ish but allows important content to bubble up)
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as retweeted_author, u1.avatar_url as author_avatar, u1.follower_count as author_follower_count, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count, " +
    "((CASE WHEN f.follower_username IS NOT NULL THEN 172800000.0 ELSE 0.0 END) + (ln(COALESCE(u1.follower_count, 0) + 1.0) * 3600000.0)) as weight_bonus " +
    "FROM messages m1 " +
    "LEFT JOIN messages m2 ON m1.retweeted_id = m2.id " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "LEFT JOIN follows f ON f.follower_username = $1 AND f.following_username = u1.username " +
    "WHERE m1.receiver_username = '' " +
    "ORDER BY (m1.timestamp + (CASE WHEN f.follower_username IS NOT NULL THEN 172800000.0 ELSE 0.0 END) + (ln(COALESCE(u1.follower_count, 0) + 1.0) * 3600000.0)) DESC " +
    "LIMIT $2 OFFSET $3",
    [currentUser, l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    authorUsername: row.sender_username,
    authorAvatar: row.author_avatar,
    authorFollowerCount: row.author_follower_count || 0,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    retweetedId: row.retweeted_id,
    retweetedAuthor: row.retweeted_author,
    likedCount: row.liked_count,
    retweetCount: row.retweet_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url
  }));
@@Database.getPersonalizedTweets.end

@async @Database.getUserTweets{username: string, limit: number, offset: number}: any
@@Database.getUserTweets.code
  const l = limit || 10;
  const o = offset || 0;
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as retweeted_author, u1.avatar_url as author_avatar, u1.follower_count as author_follower_count, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "LEFT JOIN messages m2 ON m1.retweeted_id = m2.id " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "WHERE m1.sender_username = $1 AND m1.receiver_username = '' " +
    "ORDER BY m1.timestamp DESC " +
    "LIMIT $2 OFFSET $3",
    [username, l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    authorUsername: row.sender_username,
    authorAvatar: row.author_avatar,
    authorFollowerCount: row.author_follower_count || 0,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    retweetedId: row.retweeted_id,
    retweetedAuthor: row.retweeted_author,
    likedCount: row.liked_count,
    retweetCount: row.retweet_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url
  }));
@@Database.getUserTweets.end

@async @Database.likeMessage{messageId: string, username: string}: void
@@Database.likeMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    await client.query('INSERT INTO likes (message_id, username) VALUES ($1, $2)', [messageId, username]);
    await client.query('UPDATE messages SET liked_count = liked_count + 1 WHERE id = $1', [messageId]);
    
    // Notification for like
    const msgRes = await client.query("SELECT sender_username FROM messages WHERE id = $1", [messageId]);
    if (msgRes.rows.length > 0) {
      const owner = msgRes.rows[0].sender_username;
      if (owner !== username) {
        await client.query(
          "INSERT INTO notifications (sender_username, receiver_username, action, message_id, timestamp) VALUES ($1, $2, $3, $4, $5) ON CONFLICT DO NOTHING",
          [username, owner, 'like', messageId, Date.now()]
        );
      }
    }

    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.likeMessage.end

@async @Database.unlikeMessage{messageId: string, username: string}: void
@@Database.unlikeMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    const res = await client.query('DELETE FROM likes WHERE message_id = $1 AND username = $2', [messageId, username]);
    if (res.rowCount > 0) {
      await client.query('UPDATE messages SET liked_count = liked_count - 1 WHERE id = $1', [messageId]);
    }
    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.unlikeMessage.end

@async @Database.retweetMessage{sender: string, originalId: string, ts: number}: any
@@Database.retweetMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    
    // 1. Get original tweet info (need sender_username for return object)
    const origRes = await client.query('SELECT sender_username, content, image_url FROM messages WHERE id = $1', [originalId]);
    if (origRes.rows.length === 0) {
      throw new Error("Original tweet not found (" + originalId + ")");
    }
    const origRow = origRes.rows[0];

    // 2. Prevent self-retweet
    if (origRow.sender_username === sender) {
      throw new Error("You cannot retweet your own tweet");
    }

    // 3. Check for existing retweet by this user
    const existing = await client.query(
      'SELECT id FROM messages WHERE sender_username = $1 AND retweeted_id = $2',
      [sender, originalId]
    );
    if (existing.rows.length > 0) {
      throw new Error("You have already retweeted this message");
    }

    // 4. Create retweet record
    const retweet = await client.query(
      "INSERT INTO messages (sender_username, receiver_username, content, timestamp, retweeted_id, image_url) VALUES ($1, '', $2, $3, $4, $5) RETURNING *",
      [sender, origRow.content, ts, originalId, origRow.image_url]
    );
    
    // 5. Create hashtags for retweet
    const hashtags = origRow.content.match(/#(\w+)/g);
    const retweetRow = retweet.rows[0];
    if (hashtags) {
      for (const t of hashtags) {
        const tag = t.substring(1).toLowerCase();
        await client.query(
          "INSERT INTO hashtags (tag, message_id) VALUES ($1, $2) ON CONFLICT DO NOTHING",
          [tag, retweetRow.id]
        );
      }
    }
    
    // 6. Increment original retweet count
    await client.query('UPDATE messages SET retweet_count = retweet_count + 1 WHERE id = $1', [originalId]);
    
    // Notification for retweet
    if (origRow.sender_username !== sender) {
       await client.query(
         "INSERT INTO notifications (sender_username, receiver_username, action, message_id, timestamp) VALUES ($1, $2, $3, $4, $5) ON CONFLICT DO NOTHING",
         [sender, origRow.sender_username, 'retweet', originalId, ts]
       );
    }

    await client.query('COMMIT');
    
    const row = retweet.rows[0];
    return {
      id: row.id,
      authorUsername: row.sender_username,
      content: row.content,
      timestamp: Number(row.timestamp),
      retweetedId: row.retweeted_id,
      retweetedAuthor: origRow.sender_username,
      likedCount: 0,
      retweetCount: 0,
      repliesCount: 0,
      imageUrl: row.image_url
    };
  } catch (e) {
    if (client) await client.query('ROLLBACK');
    console.error("[DB ERROR] retweetMessage:", e.name, e.message);
    throw e;
  } finally {
    if (client) client.release();
  }
@@Database.retweetMessage.end

@async @Database.getReplies{messageId: string}: any
@@Database.getReplies.code
  const res = await this.pool.query(
    "SELECT m1.*, u1.avatar_url as author_avatar, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m2 WHERE m2.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "WHERE m1.replied_to_id = $1 " +
    "ORDER BY m1.timestamp ASC",
    [messageId]
  );
  return res.rows.map(row => ({
    id: row.id,
    sender_username: row.sender_username,
    authorAvatar: row.author_avatar,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    likedCount: row.liked_count,
    retweetCount: row.retweet_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url
  }));
@@Database.getReplies.end

@async @Database.getMessagesByHashtag{tag: string, limit: number, offset: number}: any
@@Database.getMessagesByHashtag.code
  const l = limit || 10;
  const o = offset || 0;
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as retweeted_author, u1.avatar_url as author_avatar, u1.follower_count as author_follower_count, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "JOIN hashtags h ON m1.id = h.message_id " +
    "LEFT JOIN messages m2 ON m1.retweeted_id = m2.id " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "WHERE h.tag = $1 AND m1.receiver_username = '' " +
    "ORDER BY m1.timestamp DESC " +
    "LIMIT $2 OFFSET $3",
    [tag.toLowerCase(), l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    authorUsername: row.sender_username,
    authorAvatar: row.author_avatar,
    authorFollowerCount: row.author_follower_count || 0,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    retweetedId: row.retweeted_id,
    retweetedAuthor: row.retweeted_author,
    likedCount: row.liked_count,
    retweetCount: row.retweet_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url
  }));
@@Database.getMessagesByHashtag.end
@async @Database.followUser{follower: string, following: string}: void
@@Database.followUser.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    await client.query('INSERT INTO follows (follower_username, following_username) VALUES ($1, $2)', [follower, following]);
    await client.query('UPDATE users SET follower_count = follower_count + 1 WHERE username = $1', [following]);
    await client.query('UPDATE users SET following_count = following_count + 1 WHERE username = $1', [follower]);
    
    // Notification for follow: Check if one already exists to avoid spam
    const existingNotif = await client.query(
      "SELECT id FROM notifications WHERE sender_username = $1 AND receiver_username = $2 AND action = 'follow'",
      [follower, following]
    );

    
    if (existingNotif.rows.length === 0) {
      await client.query(
        "INSERT INTO notifications (sender_username, receiver_username, action, timestamp) VALUES ($1, $2, $3, $4)",
        [follower, following, 'follow', Date.now()]
      );
    } else {
      // Optional: Just update the timestamp and mark as unread to "bump" it
      await client.query(
        "UPDATE notifications SET timestamp = $1, is_read = FALSE WHERE id = $2",
        [Date.now(), existingNotif.rows[0].id]
      );
    }

    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.followUser.end

@async @Database.unfollowUser{follower: string, following: string}: void
@@Database.unfollowUser.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    const res = await client.query('DELETE FROM follows WHERE follower_username = $1 AND following_username = $2', [follower, following]);
    if (res.rowCount > 0) {
      await client.query('UPDATE users SET follower_count = GREATEST(0, follower_count - 1) WHERE username = $1', [following]);
      await client.query('UPDATE users SET following_count = GREATEST(0, following_count - 1) WHERE username = $1', [follower]);
    }
    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.unfollowUser.end

@async @Database.isFollowing{follower: string, following: string}: boolean
@@Database.isFollowing.code
  const res = await this.pool.query('SELECT 1 FROM follows WHERE follower_username = $1 AND following_username = $2', [follower, following]);
  return res.rows.length > 0;
@@Database.isFollowing.end

@async @Database.getFollowing{username: string}: string[]
@@Database.getFollowing.code
  const res = await this.pool.query('SELECT following_username FROM follows WHERE follower_username = $1', [username]);
  return res.rows.map(row => row.following_username);
@@Database.getFollowing.end

@async @Database.getFollowersDetails{username: string}: any[]
@@Database.getFollowersDetails.code
  const res = await this.pool.query(
    "SELECT u.username, u.name, u.avatar_url " +
    "FROM users u " +
    "JOIN follows f ON u.username = f.follower_username " +
    "WHERE f.following_username = $1",
    [username]
  );
  return res.rows.map(row => ({
    username: row.username,
    name: row.name,
    avatarUrl: row.avatar_url
  }));
@@Database.getFollowersDetails.end

