cliscripts->build_docker docker build -t twitter-db .
cliscripts->start_docker docker run -p 5432:5432 twitter-db

docker->start
FROM postgres:latest
ENV POSTGRES_PASSWORD=mysecretpassword
EXPOSE 5432
docker->end

extern->pg from "pg"

Database[Database.ts{pool: any}]

@Database.constructor{}
@@Database.constructor.code
  this.pool = new pg.Pool({
    user: 'postgres',
    host: 'localhost',
    database: 'postgres',
    password: 'mysecretpassword',
    port: 5432,
  });
@@Database.constructor.end

@async @Database.init{}: void
@@Database.init.code

  await this.pool.query("CREATE TABLE IF NOT EXISTS users (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), username VARCHAR(255) UNIQUE NOT NULL, name VARCHAR(255) NOT NULL, password_hash VARCHAR(255) NOT NULL);");
  await this.pool.query("CREATE TABLE IF NOT EXISTS messages (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), sender_username VARCHAR(255) NOT NULL, receiver_username VARCHAR(255) NOT NULL,content TEXT NOT NULL,timestamp BIGINT NOT NULL,replied_to_id UUID,retweeted_id UUID,liked_count INT DEFAULT 0, retweet_count INT DEFAULT 0);");
  await this.pool.query("CREATE TABLE IF NOT EXISTS likes ( id SERIAL PRIMARY KEY, message_id UUID NOT NULL REFERENCES messages(id), username VARCHAR(255) NOT NULL, UNIQUE(message_id, username));");
  console.log("Database initialized.");
@@Database.init.end

@async @Database.insertMessage{senderUsername: string, receiverUsername: string, content: string, timestamp: number, repliedToId: string, retweetedId: string}: any
@@Database.insertMessage.code
  const res = await this.pool.query(
    "INSERT INTO messages (sender_username, receiver_username, content, timestamp, replied_to_id, retweeted_id) VALUES ($1, $2, $3, $4, $5, $6) RETURNING *",
    [senderUsername, receiverUsername, content, timestamp, repliedToId || null, retweetedId || null]
  );
  return res.rows[0];
@@Database.insertMessage.end

@async @Database.getMessagesBetween{user1: string, user2: string}: any
@@Database.getMessagesBetween.code
  const res = await this.pool.query(
    "SELECT * FROM messages WHERE (sender_username = $1 AND receiver_username = $2) OR (sender_username = $2 AND receiver_username = $1) ORDER BY timestamp ASC",
    [user1, user2]
  );
  return res.rows.map(row => ({
    id: row.id,
    senderUsername: row.sender_username,
    receiverUsername: row.receiver_username,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    retweetedId: row.retweeted_id,
    likedCount: row.liked_count,
    retweetCount: row.retweet_count
  }));
@@Database.getMessagesBetween.end

@async @Database.getPublicTweets{limit: number, offset: number}: any
@@Database.getPublicTweets.code
  const l = limit || 10;
  const o = offset || 0;
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as retweeted_author, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "LEFT JOIN messages m2 ON m1.retweeted_id = m2.id " +
    "WHERE m1.receiver_username = '' " +
    "ORDER BY m1.timestamp DESC " +
    "LIMIT $1 OFFSET $2",
    [l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    authorUsername: row.sender_username,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    retweetedId: row.retweeted_id,
    retweetedAuthor: row.retweeted_author,
    likedCount: row.liked_count,
    retweetCount: row.retweet_count,
    repliesCount: Number(row.reply_count)
  }));
@@Database.getPublicTweets.end

@async @Database.likeMessage{messageId: string, username: string}: void
@@Database.likeMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    await client.query('INSERT INTO likes (message_id, username) VALUES ($1, $2)', [messageId, username]);
    await client.query('UPDATE messages SET liked_count = liked_count + 1 WHERE id = $1', [messageId]);
    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.likeMessage.end

@async @Database.unlikeMessage{messageId: string, username: string}: void
@@Database.unlikeMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    const res = await client.query('DELETE FROM likes WHERE message_id = $1 AND username = $2', [messageId, username]);
    if (res.rowCount > 0) {
      await client.query('UPDATE messages SET liked_count = liked_count - 1 WHERE id = $1', [messageId]);
    }
    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.unlikeMessage.end

@async @Database.retweetMessage{sender: string, originalId: string, ts: number}: any
@@Database.retweetMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    
    // 1. Get original tweet info (need sender_username for return object)
    const origRes = await client.query('SELECT sender_username, content FROM messages WHERE id = $1', [originalId]);
    if (origRes.rows.length === 0) {
      throw new Error("Original tweet not found (" + originalId + ")");
    }
    const origRow = origRes.rows[0];

    // 2. Prevent self-retweet
    if (origRow.sender_username === sender) {
      throw new Error("You cannot retweet your own tweet");
    }

    // 3. Check for existing retweet by this user
    const existing = await client.query(
      'SELECT id FROM messages WHERE sender_username = $1 AND retweeted_id = $2',
      [sender, originalId]
    );
    if (existing.rows.length > 0) {
      throw new Error("You have already retweeted this message");
    }

    // 4. Create retweet record
    const retweet = await client.query(
      "INSERT INTO messages (sender_username, receiver_username, content, timestamp, retweeted_id) VALUES ($1, '', $2, $3, $4) RETURNING *",
      [sender, origRow.content, ts, originalId]
    );
    
    // 5. Increment original retweet count
    await client.query('UPDATE messages SET retweet_count = retweet_count + 1 WHERE id = $1', [originalId]);
    
    await client.query('COMMIT');
    
    const row = retweet.rows[0];
    return {
      id: row.id,
      authorUsername: row.sender_username,
      content: row.content,
      timestamp: Number(row.timestamp),
      retweetedId: row.retweeted_id,
      retweetedAuthor: origRow.sender_username,
      likedCount: 0,
      retweetCount: 0,
      repliesCount: 0
    };
  } catch (e) {
    if (client) await client.query('ROLLBACK');
    console.error("[DB ERROR] retweetMessage:", e.name, e.message);
    throw e;
  } finally {
    if (client) client.release();
  }
@@Database.retweetMessage.end

@async @Database.getReplies{messageId: string}: any
@@Database.getReplies.code
  const res = await this.pool.query(
    "SELECT m1.*, " +
    "(SELECT COUNT(*) FROM messages m2 WHERE m2.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "WHERE m1.replied_to_id = $1 " +
    "ORDER BY m1.timestamp ASC",
    [messageId]
  );
  return res.rows.map(row => ({
    id: row.id,
    sender_username: row.sender_username,
    content: row.content,
    timestamp: Number(row.timestamp),
    likedCount: row.liked_count,
    retweetCount: row.retweet_count,
    repliesCount: Number(row.reply_count)
  }));
@@Database.getReplies.end

@async @Database.query{text: string, params: any}: any
@@Database.query.code
  return await this.pool.query(text, params);
@@Database.query.end
