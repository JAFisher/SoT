@async @Database.getTrendingHashtags{last24HoursMs: number, limit: number}: any
@@Database.getTrendingHashtags.code
  const res = await this.pool.query(
    "SELECT h.tag, COUNT(*) as count " +
    "FROM hashtags h " +
    "JOIN messages m ON h.message_id = m.id " +
    "WHERE m.timestamp > $1 " +
    "GROUP BY h.tag " +
    "ORDER BY count DESC " +
    "LIMIT $2",
    [last24HoursMs, limit || 10]
  );
  return res.rows.map(row => ({
    tag: row.tag,
    count: Number(row.count)
  }));
@@Database.getTrendingHashtags.end

@async @Database.getNotifications{username: string, limit: number, offset: number}: any
@@Database.getNotifications.code
  const l = limit || 25;
  const o = offset || 0;
  const res = await this.pool.query(
    "SELECT n.*, u.avatar_url as sender_avatar, u.name as sender_name, m.content as message_content, " +
    "(SELECT content FROM messages WHERE id = m.replied_to_id) as parent_content " +
    "FROM notifications n " +
    "JOIN users u ON n.sender_username = u.username " +
    "LEFT JOIN messages m ON n.message_id = m.id " +
    "WHERE n.receiver_username = $1 " +
    "ORDER BY n.timestamp DESC LIMIT $2 OFFSET $3",
    [username, l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    from: row.sender_username,
    fromName: row.sender_name,
    fromAvatar: row.sender_avatar,
    to: row.receiver_username,
    action: row.action,
    messageId: row.message_id,
    messageContent: row.message_content,
    parentContent: row.parent_content,
    timestamp: Number(row.timestamp),
    isRead: row.is_read
  }));
@@Database.getNotifications.end

@async @Database.markNotificationsRead{username: string}: void
@@Database.markNotificationsRead.code
  await this.pool.query("UPDATE notifications SET is_read = TRUE WHERE receiver_username = $1", [username]);
@@Database.markNotificationsRead.end

@async @Database.searchAll{query: string, limit: number, offset: number}: any
@@Database.searchAll.code
  const l = limit || 25;
  const o = offset || 0;
  const searchPattern = '%' + query + '%';
  const tagPattern = query.startsWith('#') ? '%' + query.substring(1) + '%' : searchPattern;

  const userRes = await this.pool.query(
    "SELECT username, name, avatar_url, follower_count, following_count FROM users " +
    "WHERE username ILIKE $1 OR name ILIKE $1 LIMIT $2 OFFSET $3",
    [searchPattern, l, o]
  );
  
  const tagRes = await this.pool.query(
    "SELECT tag, COUNT(*) as count FROM hashtags " +
    "WHERE tag ILIKE $1 GROUP BY tag LIMIT $2 OFFSET $3",
    [tagPattern, l, o]
  );

  const msgRes = await this.pool.query(
    "SELECT m.*, u.avatar_url as sender_avatar, u.name as sender_name, " +
    "(SELECT COUNT(*) FROM messages r WHERE r.replied_to_id = m.id) as replies_count " +
    "FROM messages m JOIN users u ON m.sender_username = u.username " +
    "WHERE m.content ILIKE $1 ORDER BY m.timestamp DESC LIMIT $2 OFFSET $3",
    [searchPattern, l, o]
  );

  const results = [];
  userRes.rows.forEach(r => results.push({ type: 'user', username: r.username, name: r.name, avatarUrl: r.avatar_url, followerCount: r.follower_count, followingCount: r.following_count }));
  tagRes.rows.forEach(r => results.push({ type: 'hashtag', tag: r.tag, count: Number(r.count) }));
  msgRes.rows.forEach(r => results.push({ 
    type: 'message', 
    id: r.id, 
    sender_username: r.sender_username, 
    sender_name: r.sender_name, 
    sender_avatar: r.sender_avatar, 
    content: r.content, 
    timestamp: Number(r.timestamp), 
    repliedToId: r.replied_to_id, 
    repostedId: r.reposted_id, 
    likedCount: r.liked_count, 
    repostCount: r.repost_count, 
    repliesCount: Number(r.replies_count), 
    imageUrl: r.image_url,
    viewCount: r.view_count || 0
  }));

  return results;
@@Database.searchAll.end

@async @Database.getTrendingLikes{sinceTimestamp: number, limit: number}: any
@@Database.getTrendingLikes.code
  const client = await this.pool.connect();
  try {
    const res = await client.query(`
      SELECT m1.*, 
             u1.avatar_url as author_avatar, 
             u1.follower_count as author_follower_count,
             (SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count
      FROM messages m1
      LEFT JOIN users u1 ON m1.sender_username = u1.username
      WHERE m1.timestamp >= $1 AND m1.receiver_username = '' AND m1.liked_count > 0
      ORDER BY m1.liked_count DESC, m1.timestamp DESC
      LIMIT $2
    `, [sinceTimestamp, limit]);

    return res.rows.map(row => ({
      id: row.id,
      authorUsername: row.sender_username,
      authorAvatar: row.author_avatar,
      authorFollowerCount: row.author_follower_count,
      content: row.content,
      timestamp: Number(row.timestamp),
      repliedToId: row.replied_to_id,
      repostedId: row.reposted_id,
      likedCount: row.liked_count,
      repostCount: row.repost_count,
      repliesCount: Number(row.reply_count),
      imageUrl: row.image_url,
      viewCount: row.view_count || 0
    }));
  } finally {
    client.release();
  }
@@Database.getTrendingLikes.end

@async @Database.reportMessage{reporterUsername: string, messageId: string}: void
@@Database.reportMessage.code
  await this.pool.query(
    "INSERT INTO reports (reporter_username, message_id, timestamp) VALUES ($1, $2, $3) ON CONFLICT DO NOTHING",
    [reporterUsername, messageId, Date.now()]
  );
@@Database.reportMessage.end

@async @Database.getReports{}: any[]
@@Database.getReports.code
  const res = await this.pool.query(
    "SELECT m.id as message_id, m.content, m.sender_username as reported_username, u.avatar_url as reported_avatar, m.image_url, MAX(r.timestamp) as timestamp, COUNT(r.id) as report_count " +
    "FROM reports r " +
    "JOIN messages m ON r.message_id = m.id " +
    "JOIN users u ON m.sender_username = u.username " +
    "GROUP BY m.id, m.content, m.sender_username, u.avatar_url, m.image_url " +
    "HAVING MAX(CASE WHEN r.marked_as_safe THEN 1 ELSE 0 END) = 0 " +
    "ORDER BY timestamp DESC"
  );
  return res.rows.map(row => ({
    messageId: row.message_id,
    content: row.content,
    reportedUsername: row.reported_username,
    reportedAvatar: row.reported_avatar,
    imageUrl: row.image_url,
    timestamp: Number(row.timestamp),
    reportCount: parseInt(row.report_count)
  }));
@@Database.getReports.end

@async @Database.markReportSafe{messageId: string}: void
@@Database.markReportSafe.code
  await this.pool.query("UPDATE reports SET marked_as_safe = TRUE WHERE message_id = $1", [messageId]);
@@Database.markReportSafe.end

@async @Database.deleteMessageCascade{messageId: string}: {deletedCount: number, imageUrls: string[]}
@@Database.deleteMessageCascade.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');

    // 1. Find entire tree
    const findTreeQuery = 
      "WITH RECURSIVE message_tree AS (" +
      "  SELECT id, image_url FROM messages WHERE id = $1 " +
      "  UNION ALL " +
      "  SELECT m.id, m.image_url FROM messages m " +
      "  JOIN message_tree mt ON m.replied_to_id = mt.id OR m.reposted_id = mt.id " +
      ") " +
      "SELECT id, image_url FROM message_tree;";
    
    const treeRes = await client.query(findTreeQuery, [messageId]);
    const ids = treeRes.rows.map(r => r.id);
    const imageUrls = treeRes.rows.map(r => r.image_url).filter(Boolean);

    if (ids.length === 0) {
      throw new Error("Message not found");
    }

    // 2. Delete dependent rows
    await client.query('DELETE FROM views         WHERE message_id = ANY($1)', [ids]);
    await client.query('DELETE FROM reports       WHERE message_id = ANY($1)', [ids]);
    await client.query('DELETE FROM hashtags      WHERE message_id = ANY($1)', [ids]);
    await client.query('DELETE FROM likes         WHERE message_id = ANY($1)', [ids]);
    await client.query('DELETE FROM notifications WHERE message_id = ANY($1)', [ids]);

    // 3. Delete messages themselves
    await client.query('DELETE FROM messages WHERE id = ANY($1)', [ids]);

    // 4. Delete physical images (before commit so we can rollback on error)
    const deletedImages = [];
    for (const url of imageUrls) {
      try {
        const filename = url.split('/images/').pop();
        if (filename) {
          const filePath = path.join(process.cwd(), 'public', 'images', filename);
          if (fs.existsSync(filePath)) {
            fs.unlinkSync(filePath);
            deletedImages.push(filename);
          }
        }
      } catch (fsErr) {
        console.error(`Failed to delete image ${url}:`, fsErr);
        // Decide: continue or throw? Here we continue but log.
      }
    }

    await client.query('COMMIT');

    return {
      deletedCount: ids.length,
      imageUrls: deletedImages
    };
  } catch (e) {
    console.log(e);
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.deleteMessageCascade.end

@async @Database.query{text: string, params: any}: any
@@Database.query.code
  return await this.pool.query(text, params);
@@Database.query.end
