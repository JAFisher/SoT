cliscripts->build_docker docker build -t social-db .
cliscripts->start_docker docker run -p 5432:5432 social-db

docker->start
FROM postgres:latest
ENV POSTGRES_PASSWORD=mysecretpassword
EXPOSE 5432
docker->end

extern->pg from "pg"
extern->dotenv from "dotenv"
extern->bcrypt from "bcrypt"
extern->fs from "fs"
extern->path from "path"


Database[Database.ts{pool: any}]

@Database.constructor{}
@@Database.constructor.code
  this.pool = new pg.Pool({
    user: 'postgres',
    host: 'localhost',
    database: 'postgres',
    password: 'mysecretpassword',
    port: 5432,
  });
@@Database.constructor.end

@async @Database.init{}: void
@@Database.init.code


  await this.pool.query("CREATE TABLE IF NOT EXISTS users (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), username VARCHAR(255) UNIQUE NOT NULL, email VARCHAR(255) UNIQUE NOT NULL, name VARCHAR(255) NOT NULL, password_hash VARCHAR(255) NOT NULL, avatar_url TEXT);");
  await this.pool.query("ALTER TABLE users ADD COLUMN IF NOT EXISTS email VARCHAR(255) UNIQUE;");
  await this.pool.query("ALTER TABLE users ADD COLUMN IF NOT EXISTS follower_count INT DEFAULT 0;");
  await this.pool.query("ALTER TABLE users ADD COLUMN IF NOT EXISTS following_count INT DEFAULT 0;");
  await this.pool.query("ALTER TABLE users ADD COLUMN IF NOT EXISTS banner_url TEXT;");
  await this.pool.query("ALTER TABLE users ADD COLUMN IF NOT EXISTS is_admin BOOLEAN DEFAULT FALSE;");
  
  await this.pool.query("CREATE TABLE IF NOT EXISTS messages (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), sender_username VARCHAR(255) NOT NULL, receiver_username VARCHAR(255) NOT NULL,content TEXT NOT NULL,timestamp BIGINT NOT NULL,replied_to_id UUID,reposted_id UUID,liked_count INT DEFAULT 0, repost_count INT DEFAULT 0, image_url TEXT);");
  await this.pool.query("ALTER TABLE messages ADD COLUMN IF NOT EXISTS view_count INT DEFAULT 0;");
  await this.pool.query("CREATE TABLE IF NOT EXISTS likes ( id SERIAL PRIMARY KEY, message_id UUID NOT NULL REFERENCES messages(id), username VARCHAR(255) NOT NULL, UNIQUE(message_id, username));");
  await this.pool.query("CREATE TABLE IF NOT EXISTS views (id SERIAL PRIMARY KEY, message_id UUID NOT NULL REFERENCES messages(id), username VARCHAR(255) NOT NULL, UNIQUE(message_id, username));");
  await this.pool.query("CREATE TABLE IF NOT EXISTS follows (follower_username VARCHAR(255) NOT NULL, following_username VARCHAR(255) NOT NULL, UNIQUE(follower_username, following_username));");
  await this.pool.query("CREATE TABLE IF NOT EXISTS hashtags (tag VARCHAR(255) NOT NULL, message_id UUID NOT NULL REFERENCES messages(id) ON DELETE CASCADE, PRIMARY KEY (tag, message_id));");
  await this.pool.query("CREATE TABLE IF NOT EXISTS notifications (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), sender_username VARCHAR(255) NOT NULL, receiver_username VARCHAR(255) NOT NULL, action VARCHAR(255) NOT NULL, message_id UUID, timestamp BIGINT NOT NULL, is_read BOOLEAN DEFAULT FALSE, UNIQUE(sender_username, receiver_username, action, message_id));");
  await this.pool.query("CREATE TABLE IF NOT EXISTS reports (id SERIAL PRIMARY KEY, reporter_username VARCHAR(255) REFERENCES users(username), message_id UUID REFERENCES messages(id), timestamp BIGINT, marked_as_safe BOOLEAN DEFAULT FALSE, UNIQUE(reporter_username, message_id));");
  try {
    await this.pool.query("ALTER TABLE reports ADD COLUMN IF NOT EXISTS marked_as_safe BOOLEAN DEFAULT FALSE;");
  } catch (e) {}

  dotenv.config();
  const adminUser = process.env.ADMIN_USERNAME;
  const adminPass = process.env.ADMIN_PASSWORD;

  if (adminUser && adminPass) {
    const hash = await bcrypt.hash(adminPass, 10);
    await this.pool.query(`
      INSERT INTO users (username, name, password_hash, is_admin)
      VALUES ($1, 'Admin', $2, TRUE)
      ON CONFLICT (username) DO UPDATE
      SET password_hash = $2, is_admin = TRUE
    `, [adminUser.toLowerCase(), hash]);
    console.log(`[DB] Admin user '${adminUser}' seeded/updated.`);
  }

  console.log("Database initialized (Fresh start).");

@@Database.init.end

@async @Database.insertMessage{senderUsername: string, receiverUsername: string, content: string, timestamp: number, repliedToId: string, repostedId: string, imageUrl: string}: any
@@Database.insertMessage.code
  if (content && content.length > 300) {
    throw new Error("Message content exceeds 300 characters");
  }
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    const res = await client.query(
      "INSERT INTO messages (sender_username, receiver_username, content, timestamp, replied_to_id, reposted_id, image_url) VALUES ($1, $2, $3, $4, $5, $6, $7) RETURNING *",
      [senderUsername, receiverUsername, content, timestamp, repliedToId || null, repostedId || null, imageUrl || null]
    );
    const message = res.rows[0];
    
    // Extract hashtags
    const hashtags = content.match(/#(\w+)/g);
    if (hashtags) {
      for (const t of hashtags) {
        const tag = t.substring(1).toLowerCase();
        await client.query(
          "INSERT INTO hashtags (tag, message_id) VALUES ($1, $2) ON CONFLICT DO NOTHING",
          [tag, message.id]
        );
      }
    }
    
    // Notification for mentions
    const mentionMatches = content.match(/@(\w+)/g);
    if (mentionMatches) {
      const uniqueMentions = Array.from(new Set(mentionMatches.map(m => m.substring(1))));
      for (const mentionedUser of uniqueMentions) {
        if (mentionedUser !== senderUsername) {
          await client.query(
            "INSERT INTO notifications (sender_username, receiver_username, action, message_id, timestamp) VALUES ($1, $2, $3, $4, $5) ON CONFLICT DO NOTHING",
            [senderUsername, mentionedUser, 'mention', message.id, timestamp]
          );
        }
      }
    }
    // Notification for replies
    if (repliedToId) {
      const parentRes = await client.query("SELECT sender_username FROM messages WHERE id = $1", [repliedToId]);
      if (parentRes.rows.length > 0) {
        const parentOwner = parentRes.rows[0].sender_username;
        if (parentOwner !== senderUsername) {
           await client.query(
             "INSERT INTO notifications (sender_username, receiver_username, action, message_id, timestamp) VALUES ($1, $2, $3, $4, $5) ON CONFLICT DO NOTHING",
             [senderUsername, parentOwner, 'reply', message.id, timestamp]
           );
        }
      }
    }
    
    await client.query('COMMIT');
    return message;
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.insertMessage.end

@async @Database.getMessage{id: string}: any
@@Database.getMessage.code
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as reposted_author, u1.avatar_url as author_avatar, u1.follower_count as author_follower_count, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "LEFT JOIN messages m2 ON m1.reposted_id = m2.id " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "WHERE m1.id = $1",
    [id]
  );
  if (res.rows.length === 0) return null;
  const row = res.rows[0];
  return {
    id: row.id,
    authorUsername: row.sender_username,
    authorAvatar: row.author_avatar,
    authorFollowerCount: row.author_follower_count || 0,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    repostedId: row.reposted_id,
    repostedAuthor: row.reposted_author,
    likedCount: row.liked_count,
    repostCount: row.repost_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url,
    viewCount: row.view_count || 0
  };
@@Database.getMessage.end

@async @Database.getMessagesBetween{user1: string, user2: string}: any
@@Database.getMessagesBetween.code
  const res = await this.pool.query(
    "SELECT * FROM messages WHERE (sender_username = $1 AND receiver_username = $2) OR (sender_username = $2 AND receiver_username = $1) ORDER BY timestamp ASC",
    [user1, user2]
  );
  return res.rows.map(row => ({
    id: row.id,
    senderUsername: row.sender_username,
    receiverUsername: row.receiver_username,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repostedId: row.reposted_id,
    likedCount: row.liked_count,
    repostCount: row.repost_count,
    viewCount: row.view_count || 0
  }));
@@Database.getMessagesBetween.end

@async @Database.getPublicMessages{limit: number, offset: number}: any
@@Database.getPublicMessages.code
  const l = limit || 10;
  const o = offset || 0;
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as reposted_author, u1.avatar_url as author_avatar, u1.follower_count as author_follower_count, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "LEFT JOIN messages m2 ON m1.reposted_id = m2.id " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "WHERE m1.receiver_username = '' " +
    "ORDER BY m1.timestamp DESC " +
    "LIMIT $1 OFFSET $2",
    [l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    authorUsername: row.sender_username,
    authorAvatar: row.author_avatar,
    authorFollowerCount: row.author_follower_count || 0,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    repostedId: row.reposted_id,
    repostedAuthor: row.reposted_author,
    likedCount: row.liked_count,
    repostCount: row.repost_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url,
    viewCount: row.view_count || 0
  }));
@@Database.getPublicMessages.end

@async @Database.getPersonalizedMessages{currentUser: string, limit: number, offset: number}: any
@@Database.getPersonalizedMessages.code
  const l = limit || 10;
  const o = offset || 0;
  // Weighting logic:
  // 1. Followed users get 3x higher base weight
  // 2. Higher follower count increases weight (logarithmic scale)
  // 3. Score = weight * timestamp (keeps it chronological-ish but allows important content to bubble up)
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as reposted_author, u1.avatar_url as author_avatar, u1.follower_count as author_follower_count, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count, " +
    "((CASE WHEN f.follower_username IS NOT NULL THEN 172800000.0 ELSE 0.0 END) + (ln(COALESCE(u1.follower_count, 0) + 1.0) * 3600000.0)) as weight_bonus " +
    "FROM messages m1 " +
    "LEFT JOIN messages m2 ON m1.reposted_id = m2.id " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "LEFT JOIN follows f ON f.follower_username = $1 AND f.following_username = u1.username " +
    "WHERE m1.receiver_username = '' " +
    "ORDER BY (m1.timestamp + (CASE WHEN f.follower_username IS NOT NULL THEN 172800000.0 ELSE 0.0 END) + (ln(COALESCE(u1.follower_count, 0) + 1.0) * 3600000.0)) DESC " +
    "LIMIT $2 OFFSET $3",
    [currentUser, l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    authorUsername: row.sender_username,
    authorAvatar: row.author_avatar,
    authorFollowerCount: row.author_follower_count || 0,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    repostedId: row.reposted_id,
    repostedAuthor: row.reposted_author,
    likedCount: row.liked_count,
    repostCount: row.repost_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url,
    viewCount: row.view_count || 0
  }));
@@Database.getPersonalizedMessages.end

