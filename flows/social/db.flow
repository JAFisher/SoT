@async @Database.likeMessage{messageId: string, username: string}: void
@@Database.likeMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    await client.query('INSERT INTO likes (message_id, username) VALUES ($1, $2)', [messageId, username]);
    await client.query('UPDATE messages SET liked_count = liked_count + 1 WHERE id = $1', [messageId]);
    
    // Notification for like
    const msgRes = await client.query("SELECT sender_username FROM messages WHERE id = $1", [messageId]);
    if (msgRes.rows.length > 0) {
      const owner = msgRes.rows[0].sender_username;
      if (owner !== username) {
        await client.query(
          "INSERT INTO notifications (sender_username, receiver_username, action, message_id, timestamp) VALUES ($1, $2, $3, $4, $5) ON CONFLICT DO NOTHING",
          [username, owner, 'like', messageId, Date.now()]
        );
      }
    }

    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.likeMessage.end

@async @Database.unlikeMessage{messageId: string, username: string}: void
@@Database.unlikeMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    const res = await client.query('DELETE FROM likes WHERE message_id = $1 AND username = $2', [messageId, username]);
    if (res.rowCount > 0) {
      await client.query('UPDATE messages SET liked_count = liked_count - 1 WHERE id = $1', [messageId]);
    }
    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.unlikeMessage.end

@async @Database.incrementViewCount{messageId: string, viewerUsername: string}: boolean
@@Database.incrementViewCount.code
  const client = await this.pool.connect();
  let incremented = false;
  try {
    await client.query('BEGIN');
    const res = await client.query('INSERT INTO views (message_id, username) VALUES ($1, $2) ON CONFLICT DO NOTHING RETURNING id', [messageId, viewerUsername]);
    if (res.rowCount > 0) {
      await client.query('UPDATE messages SET view_count = view_count + 1 WHERE id = $1 AND sender_username != $2', [messageId, viewerUsername]);
      incremented = true;
    }
    await client.query('COMMIT');
    return incremented;
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.incrementViewCount.end

@async @Database.repostMessage{sender: string, originalId: string, ts: number}: any
@@Database.repostMessage.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    
    // 1. Get original tweet info (need sender_username for return object)
    const origRes = await client.query('SELECT sender_username, content, image_url FROM messages WHERE id = $1', [originalId]);
    if (origRes.rows.length === 0) {
      throw new Error("Original tweet not found (" + originalId + ")");
    }
    const origRow = origRes.rows[0];

    // 2. Prevent self-repost
    if (origRow.sender_username === sender) {
      throw new Error("You cannot repost your own tweet");
    }

    // 3. Check for existing repost by this user
    const existing = await client.query(
      'SELECT id FROM messages WHERE sender_username = $1 AND reposted_id = $2',
      [sender, originalId]
    );
    if (existing.rows.length > 0) {
      throw new Error("You have already reposted this message");
    }

    // 4. Create repost record
    const repost = await client.query(
      "INSERT INTO messages (sender_username, receiver_username, content, timestamp, reposted_id, image_url) VALUES ($1, '', $2, $3, $4, $5) RETURNING *",
      [sender, origRow.content, ts, originalId, origRow.image_url]
    );
    
    // 5. Create hashtags for repost
    const hashtags = origRow.content.match(/#(\w+)/g);
    const repostRow = repost.rows[0];
    if (hashtags) {
      for (const t of hashtags) {
        const tag = t.substring(1).toLowerCase();
        await client.query(
          "INSERT INTO hashtags (tag, message_id) VALUES ($1, $2) ON CONFLICT DO NOTHING",
          [tag, repostRow.id]
        );
      }
    }
    
    // 6. Increment original repost count
    await client.query('UPDATE messages SET repost_count = repost_count + 1 WHERE id = $1', [originalId]);
    
    // Notification for repost
    if (origRow.sender_username !== sender) {
       await client.query(
         "INSERT INTO notifications (sender_username, receiver_username, action, message_id, timestamp) VALUES ($1, $2, $3, $4, $5) ON CONFLICT DO NOTHING",
         [sender, origRow.sender_username, 'repost', originalId, ts]
       );
    }

    await client.query('COMMIT');
    
    const row = repost.rows[0];
    return {
      id: row.id,
      authorUsername: row.sender_username,
      content: row.content,
      timestamp: Number(row.timestamp),
      repostedId: row.reposted_id,
      repostedAuthor: origRow.sender_username,
      likedCount: 0,
      repostCount: 0,
      repliesCount: 0,
      imageUrl: row.image_url,
      viewCount: row.view_count || 0
    };
  } catch (e) {
    if (client) await client.query('ROLLBACK');
    console.error("[DB ERROR] repostMessage:", e.name, e.message);
    throw e;
  } finally {
    if (client) client.release();
  }
@@Database.repostMessage.end

@async @Database.getReplies{messageId: string}: any
@@Database.getReplies.code
  const res = await this.pool.query(
    "SELECT m1.*, u1.avatar_url as author_avatar, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m2 WHERE m2.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "WHERE m1.replied_to_id = $1 " +
    "ORDER BY m1.timestamp ASC",
    [messageId]
  );
  return res.rows.map(row => ({
    id: row.id,
    sender_username: row.sender_username,
    authorAvatar: row.author_avatar,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    likedCount: row.liked_count,
    repostCount: row.repost_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url,
    viewCount: row.view_count || 0
  }));
@@Database.getReplies.end

@async @Database.getMessagesByHashtag{tag: string, limit: number, offset: number}: any
@@Database.getMessagesByHashtag.code
  const l = limit || 10;
  const o = offset || 0;
  const res = await this.pool.query(
    "SELECT m1.*, m2.sender_username as reposted_author, u1.avatar_url as author_avatar, u1.follower_count as author_follower_count, " +
    "m4.sender_username as parent_author, m4.content as parent_content, " +
    "(SELECT COUNT(*) FROM messages m3 WHERE m3.replied_to_id = m1.id) as reply_count " +
    "FROM messages m1 " +
    "JOIN hashtags h ON m1.id = h.message_id " +
    "LEFT JOIN messages m2 ON m1.reposted_id = m2.id " +
    "LEFT JOIN users u1 ON m1.sender_username = u1.username " +
    "LEFT JOIN messages m4 ON m1.replied_to_id = m4.id " +
    "WHERE h.tag = $1 AND m1.receiver_username = '' " +
    "ORDER BY m1.timestamp DESC " +
    "LIMIT $2 OFFSET $3",
    [tag.toLowerCase(), l, o]
  );
  return res.rows.map(row => ({
    id: row.id,
    authorUsername: row.sender_username,
    authorAvatar: row.author_avatar,
    authorFollowerCount: row.author_follower_count || 0,
    content: row.content,
    timestamp: Number(row.timestamp),
    repliedToId: row.replied_to_id,
    repliedToUsername: row.parent_author,
    parentContent: row.parent_content,
    repostedId: row.reposted_id,
    repostedAuthor: row.reposted_author,
    likedCount: row.liked_count,
    repostCount: row.repost_count,
    repliesCount: Number(row.reply_count),
    imageUrl: row.image_url,
    viewCount: row.view_count || 0
  }));
@@Database.getMessagesByHashtag.end
@async @Database.followUser{follower: string, following: string}: void
@@Database.followUser.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    await client.query('INSERT INTO follows (follower_username, following_username) VALUES ($1, $2)', [follower, following]);
    await client.query('UPDATE users SET follower_count = follower_count + 1 WHERE username = $1', [following]);
    await client.query('UPDATE users SET following_count = following_count + 1 WHERE username = $1', [follower]);
    
    // Notification for follow: Check if one already exists to avoid spam
    const existingNotif = await client.query(
      "SELECT id FROM notifications WHERE sender_username = $1 AND receiver_username = $2 AND action = 'follow'",
      [follower, following]
    );

    
    if (existingNotif.rows.length === 0) {
      await client.query(
        "INSERT INTO notifications (sender_username, receiver_username, action, timestamp) VALUES ($1, $2, $3, $4)",
        [follower, following, 'follow', Date.now()]
      );
    } else {
      // Optional: Just update the timestamp and mark as unread to "bump" it
      await client.query(
        "UPDATE notifications SET timestamp = $1, is_read = FALSE WHERE id = $2",
        [Date.now(), existingNotif.rows[0].id]
      );
    }

    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.followUser.end

@async @Database.unfollowUser{follower: string, following: string}: void
@@Database.unfollowUser.code
  const client = await this.pool.connect();
  try {
    await client.query('BEGIN');
    const res = await client.query('DELETE FROM follows WHERE follower_username = $1 AND following_username = $2', [follower, following]);
    if (res.rowCount > 0) {
      await client.query('UPDATE users SET follower_count = GREATEST(0, follower_count - 1) WHERE username = $1', [following]);
      await client.query('UPDATE users SET following_count = GREATEST(0, following_count - 1) WHERE username = $1', [follower]);
    }
    await client.query('COMMIT');
  } catch (e) {
    await client.query('ROLLBACK');
    throw e;
  } finally {
    client.release();
  }
@@Database.unfollowUser.end

@async @Database.isFollowing{follower: string, following: string}: boolean
@@Database.isFollowing.code
  const res = await this.pool.query('SELECT 1 FROM follows WHERE follower_username = $1 AND following_username = $2', [follower, following]);
  return res.rows.length > 0;
@@Database.isFollowing.end

