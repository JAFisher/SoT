include->authfe.flow

type->Message {id: string, senderUsername: string, receiverUsername: string, content: string, timestamp: number}

Messaging[Messaging.ts{messages: Array}]
Messaging --> AuthFE

@Messaging.constructor{}
@@Messaging.constructor.code
  this.messages = [];
@@Messaging.constructor.end

@async @Messaging.sendMessage{senderUsername: string, receiverUsername: string, content: string, repliedToId: string, repostedId: string}: Message
@@Messaging.sendMessage.code
  const token = localStorage.getItem('token');
  const response = await fetch('http://localhost:8080/api/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + token
    },
    body: JSON.stringify({ receiverUsername, content, repliedToId, repostedId })
  });
  if (!response.ok) throw new Error("Failed to send message");
  return await response.json();
@@Messaging.sendMessage.end

@async @Messaging.getMessagesBetween{user1: string, user2: string}: any
@@Messaging.getMessagesBetween.code
  const token = localStorage.getItem('token');
  const response = await fetch('http://localhost:8080/api/messages?with=' + user2, {
    headers: {
      'Authorization': 'Bearer ' + token
    }
  });
  if (!response.ok) throw new Error("Failed to fetch messages");
  return await response.json();
@@Messaging.getMessagesBetween.end
