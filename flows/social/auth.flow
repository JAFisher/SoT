include->db.flow
extern->jwt from "jsonwebtoken"
extern->bcrypt from "bcrypt"
extern->crypto from "crypto"

type->User {id: string, username: string, email: string, name: string, avatarUrl: string, followerCount: number, followingCount: number, isAdmin: boolean}
type->AuthResponse {token: string, refreshToken: string, user: User}

Auth[Auth.ts{db: any, jwtSecret: string, jwtRefreshSecret: string}]
Auth --> Database

@Auth.constructor{}
@@Auth.constructor.code
  this.db = new Database();
  this.jwtSecret = "super-secret-key-change-me";
  this.jwtRefreshSecret = "super-secret-refresh-key";
@@Auth.constructor.end

@async @Auth.init{}: void
@@Auth.init.code
  await this.db.init();
@@Auth.init.end

@async @Auth.register{username: string, email: string, name: string, pass: string}: AuthResponse
@@Auth.register.code
  const lowerUsername = username.toLowerCase();
  const lowerEmail = email.toLowerCase();
  
  if (lowerUsername.includes('@')) {
    throw new Error("Username cannot contain '@' symbol");
  }

  const hash = await bcrypt.hash(pass, 10);
  try {
    const result = await this.db.query(
      "INSERT INTO users (username, email, name, password_hash) VALUES ($1, $2, $3, $4) RETURNING id, username, email, name, avatar_url, follower_count, following_count, is_admin",
      [lowerUsername, lowerEmail, name, hash]
    );
    const row = result.rows[0];
    const user = { id: row.id, username: row.username, email: row.email, name: row.name, avatarUrl: row.avatar_url, followerCount: row.follower_count || 0, followingCount: row.following_count || 0, isAdmin: !!row.is_admin };

    return this.generateTokens(user);
  } catch (error) {
    throw new Error("User registration failed (possibly duplicate username or email)");
  }
@@Auth.register.end

@async @Auth.login{username: string, pass: string}: AuthResponse
@@Auth.login.code
  const lowerIdentifier = username.toLowerCase();
  const result = await this.db.query("SELECT * FROM users WHERE username = $1 OR email = $1", [lowerIdentifier]);
  if (result.rows.length === 0) {
    throw new Error("User not found");
  }
  const userRow = result.rows[0];
  const valid = await bcrypt.compare(pass, userRow.password_hash);
  if (!valid) {
    throw new Error("Invalid password");
  }
  
  const user = { id: userRow.id, username: userRow.username, email: userRow.email, name: userRow.name, avatarUrl: userRow.avatar_url, followerCount: userRow.follower_count || 0, followingCount: userRow.following_count || 0, isAdmin: !!userRow.is_admin };
  return this.generateTokens(user);
@@Auth.login.end

@Auth.generateTokens{user: User}: AuthResponse
@@Auth.generateTokens.code
  const token = jwt.sign(user, this.jwtSecret, { expiresIn: "1h" });
  const refreshToken = jwt.sign(user, this.jwtRefreshSecret, { expiresIn: "7d" });
  return { token, refreshToken, user };
@@Auth.generateTokens.end

@Auth.refresh{refreshToken: string}: AuthResponse
@@Auth.refresh.code
  try {
    // Note: The prompt asks for 10 minute refresh via the client. This endpoint verifies
    // the long-lived refresh token and returns a fresh 1h token. The client can call this
    // every 10 mins.
    const decoded = jwt.verify(refreshToken, this.jwtRefreshSecret);
    const user = { id: decoded.id, username: decoded.username, email: decoded.email, name: decoded.name, avatarUrl: decoded.avatarUrl, followerCount: decoded.followerCount || 0, followingCount: decoded.followingCount || 0, isAdmin: !!decoded.isAdmin };
    return this.generateTokens(user);
  } catch (err) {
    throw new Error("Invalid or expired refresh token");
  }
@@Auth.refresh.end

@async @Auth.forgotPassword{email: string}: void
@@Auth.forgotPassword.code
  const user = await this.db.getUserByEmail(email);
  if (!user) {
    // We don't want to leak if a user exists, but for this exercise we might.
    // However, best practice is to always say "If an account exists..."
    return;
  }

  // Generate UUID token
  const token = crypto.randomUUID();
  const expiresAt = Date.now() + 3600000; // 1 hour

  await this.db.upsertResetToken(email, token, expiresAt);

  // Send email via Brevo
  const brevoApiKey = process.env.BREVO_API_KEY;
  if (!brevoApiKey) {
      console.error("[AUTH] BREVO_API_KEY not found in environment.");
      return;
  }

  const resetLink = `http://localhost:3000/reset-password.html?token=${token}&email=${encodeURIComponent(email)}`;
  
  try {
    const response = await fetch("https://api.brevo.com/v3/smtp/email", {
      method: "POST",
      headers: {
        "accept": "application/json",
        "api-key": brevoApiKey,
        "content-type": "application/json"
      },
      body: JSON.stringify({
        sender: { name: "Social Media App", email: "no-reply@sot-app.com" },
        to: [{ email: email }],
        subject: "Reset Your Password",
        htmlContent: `
          <html>
            <body>
              <h1>Password Reset Request</h1>
              <p>Hello,</p>
              <p>You requested a password reset. Use the code below or click the link to reset your password:</p>
              <h2 style="letter-spacing: 5px;">${token}</h2>
              <p><a href="${resetLink}">Reset Password</a></p>
              <p>This link will expire in 1 hour.</p>
              <p>If you didn't request this, please ignore this email.</p>
            </body>
          </html>
        `
      })
    });

    if (!response.ok) {
        const errData = await response.json();
        console.error("[AUTH] Brevo API Error:", errData);
    }
  } catch (e) {
    console.error("[AUTH] Failed to send reset email:", e);
  }
@@Auth.forgotPassword.end

@async @Auth.resetPassword{email: string, token: string, newPass: string}: void
@@Auth.resetPassword.code
  const resetData = await this.db.getResetToken(email);
  if (!resetData || resetData.token !== token || resetData.expires_at < Date.now()) {
    throw new Error("Invalid or expired reset token");
  }

  const hash = await bcrypt.hash(newPass, 10);
  await this.db.updatePassword(email, hash);
  await this.db.deleteResetToken(email);
@@Auth.resetPassword.end

@Auth.verifyToken{token: string}: User
@@Auth.verifyToken.code
  try {
    return jwt.verify(token, this.jwtSecret);
  } catch (err) {
    throw new Error("Invalid or expired token");
  }
@@Auth.verifyToken.end
