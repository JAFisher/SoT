@async @Feed.deleteMessage{messageId: string}: any
@@Feed.deleteMessage.code
  const response = await fetch("http://localhost:8080/api/admin/messages/" + messageId, {
    method: "DELETE",
    headers: {
      "Authorization": "Bearer " + window.app.auth.token
    }
  });
  if (!response.ok) throw new Error("Failed to delete tweet");
  return await response.json();
@@Feed.deleteMessage.end

@async @Feed.markReportSafe{messageId: string}: any
@@Feed.markReportSafe.code
  const response = await fetch("http://localhost:8080/api/admin/reports/" + messageId + "/safe", {
    method: "POST",
    headers: {
      "Authorization": "Bearer " + window.app.auth.token
    }
  });
  if (!response.ok) throw new Error("Failed to mark report as safe");
  return await response.json();
@@Feed.markReportSafe.end
