@@Feed.viewMessage.end


@async @Feed.getTimeline{limit: number, offset: number}: any
@@Feed.getTimeline.code
  const l = limit || 10;
  const o = offset || 0;
  const res = await fetch("http://localhost:8080/api/messages?limit=" + l + "&offset=" + o, {
    headers: {
      "Authorization": "Bearer " + (window.app.auth ? window.app.auth.token : "")
    }
  });
  return await res.json();
@@Feed.getTimeline.end

@async @Feed.getMessage{id: string}: any
@@Feed.getMessage.code
  const res = await fetch("http://localhost:8080/api/messages?id=" + id, {
    headers: {
      "Authorization": "Bearer " + (window.app.auth ? window.app.auth.token : "")
    }
  });
  if (!res.ok) throw new Error("Message not found");
  return await res.json();
@@Feed.getMessage.end
 
 @async @Feed.getHashtagFeed{tag: string, limit: number, offset: number}: any
 @@Feed.getHashtagFeed.code
   const l = limit || 10;
   const o = offset || 0;
   const res = await fetch("http://localhost:8080/api/messages/hashtag?tag=" + encodeURIComponent(tag) + "&limit=" + l + "&offset=" + o);
   return await res.json();
 @@Feed.getHashtagFeed.end

@async @Feed.getUserMessages{username: string, limit: number, offset: number}: any
@@Feed.getUserMessages.code
  const l = limit || 10;
  const o = offset || 0;
  const response = await fetch('http://localhost:8080/api/messages?username=' + username + '&limit=' + l + '&offset=' + o);
  if (!response.ok) throw new Error("Failed to fetch user tweets");
  return await response.json();
@@Feed.getUserMessages.end
@async @Feed.getReplies{messageId: string}: any
@@Feed.getReplies.code
  const response = await fetch('http://localhost:8080/api/replies?id=' + messageId);
  if (!response.ok) throw new Error("Failed to fetch replies");
  return await response.json();
@@Feed.getReplies.end

@async @Feed.uploadImage{base64Data: string}: any
@@Feed.uploadImage.code

 
  const response = await fetch("http://localhost:8080/api/upload", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + window.app.auth.token
    },
    body: JSON.stringify({ base64Data })
  });
  if (!response.ok) {
    const err = await response.json();
    throw new Error(err.error || "Upload failed");
  }
  return await response.json();
@@Feed.uploadImage.end
