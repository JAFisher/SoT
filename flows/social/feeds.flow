include->authfe.flow

type->Message {id: string, authorUsername: string, content: string, timestamp: number}

Feed[Feed.ts{tweets: Array}]
Feed --> AuthFE

@Feed.constructor{}
@@Feed.constructor.code
  this.tweets = [];
@@Feed.constructor.end

@async @Feed.postMessage{senderUsername: string, content: string, repliedToId: string, repostedId: string, imageUrl: string}: any
@@Feed.postMessage.code
  const response = await fetch("http://localhost:8080/api/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + window.app.auth.token
    },
    body: JSON.stringify({ senderUsername, content, repliedToId, repostedId, imageUrl })
  });
  return await response.json();
@@Feed.postMessage.end

@async @Feed.likeMessage{messageId: string}: any
@@Feed.likeMessage.code
  const response = await fetch('http://localhost:8080/api/like', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + window.app.auth.token
    },
    body: JSON.stringify({ messageId })
  });
  if (!response.ok) throw new Error("Failed to like");
  return await response.json();
@@Feed.likeMessage.end

@async @Feed.unlikeMessage{messageId: string}: any
@@Feed.unlikeMessage.code
  const response = await fetch('http://localhost:8080/api/unlike', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + window.app.auth.token
    },
    body: JSON.stringify({ messageId })
  });
  if (!response.ok) throw new Error("Failed to unlike");
  return await response.json();
@@Feed.unlikeMessage.end

@async @Feed.repostMessage{originalId: string}: any
@@Feed.repostMessage.code
  const response = await fetch('http://localhost:8080/api/repost', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + window.app.auth.token
    },
    body: JSON.stringify({ originalId })
  });
  
  const data = await response.json();
  return { ok: response.ok, status: response.status, data };
@@Feed.repostMessage.end

@async @Feed.viewMessage{messageId: string}: any
@@Feed.viewMessage.code
  const response = await fetch('http://localhost:8080/api/message/view', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
