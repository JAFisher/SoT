include->authfe.flow
include->feeds.flow

AdminPage[AdminPage.ts{auth: any, feed: any}]
AdminPage --> AuthFE
AdminPage --> Feed

@AdminPage.constructor{}
@@AdminPage.constructor.code
  this.auth = new AuthFE();
  this.feed = new Feed();
@@AdminPage.constructor.end

@async @AdminPage.init{}: void
@@AdminPage.init.code
  if (!this.auth.currentUser || !this.auth.currentUser.isAdmin) {
    window.location.href = "dashboard.html";
    console.log("Admin not initialized");
    return;
  }
  console.log("Admin initialized");
@@AdminPage.init.end

@async @AdminPage.renderReports{containerId: string}: void
@@AdminPage.renderReports.code
  const container = document.getElementById(containerId);
  if (!container) return;
  
  try {
    const reports = await this.feed.getReports();
    if (reports.length === 0) {
      container.innerHTML = "<div class='empty-reports'>No reports found.</div>";
      return;
    }
    
    let html = "<div class='reports-list'>";
    reports.forEach(r => {
      html += "<div class=\"report-item\" style=\"border-bottom: 1px solid var(--border-color); padding: 15px 0;\">" +
                "<div style=\"display: flex; justify-content: space-between; margin-bottom: 8px;\">" +
                  "<span style=\"font-weight: bold; color: var(--text-primary);\">Reported Message</span>" +
                  "<span style=\"font-size: 0.8em; color: var(--text-secondary);\">" + new Date(r.timestamp).toLocaleString() + "</span>" +
                "</div>" +
                "<div style=\"margin-bottom: 10px; padding: 10px; background: var(--bg-primary); border-radius: var(--radius-md);\">" +
                  "<div style=\"display: flex; align-items: center; gap: 8px; margin-bottom: 5px;\">" +
                    "<img src=\"" + r.reportedAvatar + "\" style=\"width: 24px; height: 24px; border-radius: 50%;\">" +
                    "<span style=\"font-weight: 600;\">@" + r.reportedUsername + "</span>" +
                  "</div>" +
                  "<div style=\"color: var(--text-primary); font-size: 0.95em;\">" + r.content + "</div>" +
                  (r.imageUrl ? "<img src=\"" + r.imageUrl + "\" style=\"width: 100%; max-width: 300px; border-radius: 8px; margin-top: 10px; border: 1px solid var(--border-color); display: block;\">" : "") +
                "</div>" +
                "<div style=\"font-size: 0.85em; color: var(--text-secondary); display: flex; justify-content: space-between; align-items: center;\">" +
                  "<span>Reports: <span style=\"font-weight: 500; color: var(--primary-color);\">" + r.reportCount + "</span></span>" +
                  "<div>" +
                    "<button class=\"message-btn safe-btn\" style=\"background: var(--accent-color, #1da1f2); color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; margin-bottom:12px; font-weight: bold; margin-right: 8px;\" onclick=\"window.app.adminPage.markReportSafe('" + r.messageId + "', 'reports-container')\">Mark as Safe</button>" +
                    "<button class=\"message-btn delete-btn\" style=\"background: #ff4444; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; margin-bottom:12px; font-weight: bold;\" onclick=\"window.app.adminPage.deleteMessage('" + r.messageId + "', 'reports-container')\">Delete & Cascade</button>" +
                  "</div>" +
                "</div>" +
              "</div>";
    });
    html += "</div>";
    container.innerHTML = html;
  } catch (e) {
    container.innerHTML = "<div class='error'>Failed to load reports: " + e.message + "</div>";
  }
@@AdminPage.renderReports.end

@async @AdminPage.markReportSafe{messageId: string, containerId: string}: void
@@AdminPage.markReportSafe.code
  try {
    await this.feed.markReportSafe(messageId);
    await this.renderReports(containerId);
  } catch (e) {
    alert("Failed to mark report as safe: " + e.message);
  }
@@AdminPage.markReportSafe.end

@async @AdminPage.deleteMessage{messageId: string, containerId: string}: void
@@AdminPage.deleteMessage.code
  if (!confirm("Are you sure you want to delete this message and ALL its replies/reposts? This action cannot be undone and will also remove associated images.")) return;
  
  try {
    await this.feed.deleteMessage(messageId);
    await this.renderReports(containerId);
  } catch (e) {
    alert("Failed to delete message: " + e.message);
  }
@@AdminPage.deleteMessage.end


