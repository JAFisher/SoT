%% Database Design System
type->User {id: number, username: string, email: string}
type->QueryOptions {limit: number, offset: number}

interface->IRepository {
    findMany:(options: QueryOptions): Promise<Array<User>>,
    findOne:(id: number): Promise<User>
}

DB[Database.ts]
@Database.connect: void
@@Database.connect.code
  console.log("Connected to modular database...");
@@Database.connect.end
