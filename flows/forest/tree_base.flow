extern->three from "three"@0.183.2

Tree[Tree.ts{trunkHeight: number, trunkRadius: number, canopyRadius: number, canopyColor: string, leafType: string, mesh: any}]
@Tree.constructor{}
@@Tree.constructor.code
  this.trunkHeight = 2;
  this.trunkRadius = 0.2;
  this.canopyRadius = 1;
  this.canopyColor = '#228b22';
  this.leafType = 'round';
@@Tree.constructor.end

Forest[Forest.ts{trees: Tree[]}]
@Forest.constructor{}
@@Forest.constructor.code
  this.trees = [];
@@Forest.constructor.end

@Forest.addTree{tree: Tree}: void
@@Forest.addTree.code
  this.trees.push(tree);
@@Forest.addTree.end
