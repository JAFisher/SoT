extern->three from "three"@0.183.2
include->tree_base.flow

ForestView[ForestView.ts{forest: Forest, scene: any, camera: any, renderer: any, keys: any, yaw: number, pitch: number}]
@ForestView.constructor{forest: Forest}
@@ForestView.constructor.code
  this.forest = forest;
  this.keys = {};
  this.yaw = 0;
  this.pitch = 0;
@@ForestView.constructor.end

@init{}
@@ForestView.init.code
  this.scene = new three.Scene();
  this.scene.background = new three.Color('#87ceeb');
  
  this.camera = new three.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
  this.camera.position.set(0, 5, 20);
  
  this.renderer = new three.WebGLRenderer({ antialias: true });
  this.renderer.setSize(window.innerWidth, window.innerHeight);
  document.getElementById('canvas-container').appendChild(this.renderer.domElement);
  
  const ambientLight = new three.AmbientLight(0xffffff, 0.6);
  this.scene.add(ambientLight);
  
  const directionalLight = new three.DirectionalLight(0xffffff, 0.8);
  directionalLight.position.set(10, 20, 10);
  this.scene.add(directionalLight);
  
  const groundGeo = new three.PlaneGeometry(200, 200);
  const groundMat = new three.MeshStandardMaterial({ color: '#3d522b' });
  const ground = new three.Mesh(groundGeo, groundMat);
  ground.rotation.x = -Math.PI / 2;
  this.scene.add(ground);
  
  this.forest.trees.forEach((tree, index) => {
    const x = (index % 20) * 10 - 100 + (Math.random() * 4 - 2);
    const z = Math.floor(index / 20) * 10 - 100 + (Math.random() * 4 - 2);
    
    // Trunk
    const trunkGeo = new three.CylinderGeometry(tree.trunkRadius || 0.2, tree.trunkRadius || 0.2, tree.trunkHeight);
    const trunkMat = new three.MeshStandardMaterial({ color: '#5d4037' });
    const trunk = new three.Mesh(trunkGeo, trunkMat);
    trunk.position.set(x, tree.trunkHeight / 2, z);
    this.scene.add(trunk);
    
    // Canopy
    const canopyGeo = new three.SphereGeometry(tree.canopyRadius);
    const canopyMat = new three.MeshStandardMaterial({ color: tree.canopyColor });
    const canopy = new three.Mesh(canopyGeo, canopyMat);
    canopy.position.set(x, tree.trunkHeight + tree.canopyRadius * 0.8, z);
    this.scene.add(canopy);
  });

  // Controls
  window.addEventListener('keydown', (e) => this.keys[e.code] = true);
  window.addEventListener('keyup', (e) => this.keys[e.code] = false);
  
  document.addEventListener('mousemove', (e) => {
    if (document.pointerLockElement === document.body) {
      this.yaw -= e.movementX * 0.002;
      this.pitch -= e.movementY * 0.002;
      this.pitch = Math.max(-Math.PI/2, Math.min(Math.PI/2, this.pitch));
    }
  });

  document.body.addEventListener('click', () => {
    document.body.requestPointerLock();
  });
@@ForestView.init.end

@animate{}
@@ForestView.animate.code
  requestAnimationFrame(() => this.animate());
  
  // Movement
  const speed = 0.2;
  const direction = new three.Vector3();
  if (this.keys['KeyW']) direction.z -= 1;
  if (this.keys['KeyS']) direction.z += 1;
  if (this.keys['KeyA']) direction.x -= 1;
  if (this.keys['KeyD']) direction.x += 1;
  
  if (direction.lengthSq() > 0) {
    direction.normalize().multiplyScalar(speed);
    direction.applyEuler(new three.Euler(0, this.yaw, 0));
    this.camera.position.add(direction);
  }
  
  this.camera.rotation.set(this.pitch, this.yaw, 0, 'YXZ');
  
  this.renderer.render(this.scene, this.camera);
@@ForestView.animate.end
