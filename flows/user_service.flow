include->db.flow
include->notification_service.flow

UserService[UserService.ts{monitor: Monitor}]

UserService --> DB
UserService --> Monitor

@UserService.constructor
@@UserService.constructor.code
  this.monitor = new Monitor();
@@UserService.constructor.end

@UserService.getUser{id: number}: Promise<User>
@@UserService.getUser.code
  this.monitor.logAction(`Fetching user ${id}`, true);
  const db = new Database();
  db.connect();
  return { id, username: "flow_user", email: "user@flow.com" };
@@UserService.getUser.end

@async @main.code
  const us = new UserService();
  const user = await us.getUser(1);
  console.log("Modular Flow Result:", user);
@main.end
