graph TD
  %% ---- Base Class ----
  Entity[Entity.ts{id: string, name: string, health: number, isAlive: boolean}]

  %% ---- New Node Definition (The Missing Piece) ----
  Skill[Skill.ts{name: string, manaCost: number, damageType: DamageType}]

  %% ---- Classes & Composition ----
  Player[Player.ts{level: number, stats: Stats, weapon: Weapon, skills: Skill[]}] ---|> Entity[Entity.ts]
  Enemy[Enemy.ts{lootTable: string[], stats: Stats}] ---|> Entity[Entity.ts]
  
  %% This tells the generator to import Skill into Player
  Player --> Skill
  
  %% ---- Types & Interfaces ----
  type->DamageType{"PHYSICAL" | "FIRE" | "VOID"}
  type->Stats{str: number, int: number, agi: number, def: number}
  interface->IDamageable{takeDamage: (amount: number, type: DamageType) => void}

  %% ---- Logic: Entity Take Damage ----
  @Entity.takeDamage{amount: number, type: DamageType}: void
  @@Entity.takeDamage.code
    let resistance = 0;
    if (type === "FIRE") resistance = 5; 
    const finalDamage = Math.max(1, amount - resistance);
    this.health -= finalDamage;
    if (this.health <= 0) this.isAlive = false;
    console.log(this.name + " took " + finalDamage + " [" + type + "] damage.");
  @@Entity.takeDamage.end

  %% ---- Logic: Skill Execution ----
  @Skill.cast{caster: Player, target: Entity}: boolean
  @@Skill.cast.code
    console.log(caster.name + " casts " + this.name + "!");
    const magicDamage = caster.stats.int * 2.5;
    // Note: We are calling the method we just defined in Entity
    target.takeDamage(magicDamage, this.damageType);
    return true;
  @@Skill.cast.end

  %% ---- Main Entry ----
  @@main.code
    async function runDemo() {
      const hero = new Player();
      hero.name = "Fire Mage";
      hero.stats = { str: 5, int: 25, agi: 10, def: 5 };

      const fireball = new Skill();
      fireball.name = "Inferno Blast";
      fireball.manaCost = 20;
      fireball.damageType = "FIRE";
      
      hero.skills = [fireball];

      const boss = new Enemy();
      boss.name = "Frost Giant";
      boss.health = 200;
      boss.isAlive = true;

      hero.skills[0].cast(hero, boss);
    }
    runDemo();
  @@main.end