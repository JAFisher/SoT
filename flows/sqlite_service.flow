graph TD
    include->shared/db_types.flow
    extern->sqlite3 from "sqlite3"

    DB[SqliteDatabase.ts]
    DB ---|> IDatabase

    @SqliteDatabase.constructor
    @@SqliteDatabase.constructor.code
        this.db = new sqlite3.Database(":memory:");
    @@SqliteDatabase.constructor.end

    @async @SqliteDatabase.init: Promise<void>
    @@SqliteDatabase.init.code
        return new Promise((resolve, reject) => {
            this.db.run("CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT)", (err) => {
                if (err) reject(err);
                else resolve();
            });
        });
    @@SqliteDatabase.init.end

    @async @SqliteDatabase.addUser{name: string, email: string}: Promise<void>
    @@SqliteDatabase.addUser.code
        return new Promise((resolve, reject) => {
            this.db.run("INSERT INTO users (name, email) VALUES (?, ?)", [name, email], (err) => {
                if (err) reject(err);
                else resolve();
            });
        });
    @@SqliteDatabase.addUser.end

    @async @SqliteDatabase.getUsers: Promise<Array<UserRecord>>
    @@SqliteDatabase.getUsers.code
        return new Promise((resolve, reject) => {
            this.db.all("SELECT * FROM users", (err, rows) => {
                if (err) reject(err);
                else resolve(rows);
            });
        });
    @@SqliteDatabase.getUsers.end

    @async @main.code
        const db = new SqliteDatabase();
        
        console.log("🚀 Initializing SQLite DB...");
        await db.init();

        console.log("📝 Adding users...");
        await db.addUser("Alice", "alice@example.com");
        await db.addUser("Bob", "bob@example.com");

        console.log("🔍 Querying users...");
        const users = await db.getUsers();
        console.log("✅ Users in DB:", users);
    @main.end
